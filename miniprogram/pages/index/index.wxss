.page {
  min-height: 100vh;
  background: #f6f7fe;
  color: #111827;
}

.page-shell {
  padding: 0 20rpx calc(132rpx + env(safe-area-inset-bottom));
}

.head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.head-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.head-kicker,
.panel-kicker {
  font-size: 17rpx;
  line-height: 1;
  letter-spacing: 1.2rpx;
  color: #4f46e5;
}

.head-title {
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #111827;
}

.user-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 18rpx 12rpx 12rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8eaff;
  color: #4338ca;
  font-size: 24rpx;
  font-weight: 700;
}

.user-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.panel-hint,
.rank-link,
.collection-link {
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 600;
}

.panel-hint-muted {
  color: #667085;
}

.user-tier {
  font-size: 17rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #667085;
}

.user-streak {
  font-size: 17rpx;
  line-height: 1.1;
  color: #4338ca;
  font-weight: 700;
}

.hero-card {
  position: relative;
  margin-top: 18rpx;
  height: 276rpx;
  border-radius: 36rpx;
  overflow: hidden;
}

.hero-image,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(180deg, rgba(17, 24, 39, 0.02) 8%, rgba(17, 24, 39, 0.58) 100%);
}

.hero-chip {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  z-index: 1;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #4338ca;
  font-size: 31rpx;
  font-weight: 500;
}

.hero-copy {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  z-index: 1;
}

.hero-title {
  font-size: 33rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #ffffff;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.3;
  color: #f5f3ff;
}

.panel {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.panel-creation {
  background: #f8f7fe;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.panel-head-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.panel-kicker-purple,
.panel-hint-purple {
  color: #7c3aed;
}

.panel-kicker-creation,
.panel-kicker-collection {
  font-size: 13rpx;
}

.panel-title {
  font-size: 35rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #111827;
}

.rank-row,
.collection-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 72rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #eef1ff;
}

.rank-tag {
  min-width: 64rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #6366f1;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 500;
}

.rank-title,
.collection-title {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #111827;
}

.rank-link,
.collection-link {
  color: #4338ca;
}

.tool-grid {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tool-card {
  position: relative;
  width: calc((100% - 12rpx) / 2);
  min-height: 100rpx;
  padding: 16rpx 58rpx 16rpx 16rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.tool-card-gradient {
  background: linear-gradient(180deg, #8b5cf6 0%, #6366f1 100%);
}

.tool-card-blue {
  background: #dbeafe;
}

.tool-card-purple {
  background: #f3eeff;
}

.tool-card-indigo {
  background: #e9e7ff;
}

.tool-title {
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 700;
}

.tool-card-gradient .tool-title {
  color: #ffffff;
}

.tool-card-blue .tool-title,
.tool-card-purple .tool-title {
  color: #111827;
}

.tool-card-indigo .tool-title {
  color: #312e81;
}

.tool-meta {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.2;
}

.tool-card-gradient .tool-meta {
  color: #e0e7ff;
}

.tool-card-blue .tool-meta {
  color: #5b6b8a;
}

.tool-card-purple .tool-meta {
  color: #7c3aed;
}

.tool-card-indigo .tool-meta {
  color: #5b21b6;
}

.tool-icon-box {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon-box-gradient {
  background: rgba(255, 255, 255, 0.2);
}

.tool-icon-box-blue {
  background: #bfdbfe;
}

.tool-icon-box-purple {
  background: #e9d5ff;
}

.tool-icon-box-indigo {
  background: #ddd6fe;
}

.tool-icon-target,
.tool-icon-pen,
.tool-icon-sparkles,
.tool-icon-send {
  position: relative;
  width: 28rpx;
  height: 28rpx;
}

.target-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid #ffffff;
}

.target-ring-inner {
  inset: 7rpx;
}

.target-dot {
  position: absolute;
  top: 11rpx;
  left: 11rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #ffffff;
}

.target-line {
  position: absolute;
  background: #ffffff;
  border-radius: 999rpx;
}

.target-line-horizontal {
  left: 2rpx;
  right: 2rpx;
  top: 13rpx;
  height: 2rpx;
}

.target-line-vertical {
  top: 2rpx;
  bottom: 2rpx;
  left: 13rpx;
  width: 2rpx;
}

.pen-body {
  position: absolute;
  top: 11rpx;
  left: 4rpx;
  width: 22rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #1e40af;
  transform: rotate(-35deg);
  transform-origin: center;
}

.pen-tip {
  position: absolute;
  right: 4rpx;
  top: 3rpx;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 10rpx solid #1e40af;
  transform: rotate(10deg);
}

.pen-cut {
  position: absolute;
  left: 8rpx;
  bottom: 7rpx;
  width: 8rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #1e40af;
  transform: rotate(-35deg);
}

.sparkle-ray {
  position: absolute;
  background: #6d28d9;
  border-radius: 999rpx;
}

.sparkle-ray-vertical {
  top: 2rpx;
  bottom: 2rpx;
  left: 13rpx;
  width: 2rpx;
}

.sparkle-ray-horizontal {
  left: 2rpx;
  right: 2rpx;
  top: 13rpx;
  height: 2rpx;
}

.sparkle-ray-diagonal-a,
.sparkle-ray-diagonal-b {
  top: 4rpx;
  left: 13rpx;
  width: 2rpx;
  height: 20rpx;
  transform-origin: center;
}

.sparkle-ray-diagonal-a {
  transform: rotate(45deg);
}

.sparkle-ray-diagonal-b {
  transform: rotate(-45deg);
}

.sparkle-core {
  position: absolute;
  top: 9rpx;
  left: 9rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 4rpx;
  background: #6d28d9;
  transform: rotate(45deg);
}

.send-outline {
  position: absolute;
  inset: 5rpx 3rpx 7rpx 4rpx;
  border-top: 2rpx solid #4338ca;
  border-right: 2rpx solid #4338ca;
  transform: skewX(-24deg) rotate(12deg);
}

.send-tail {
  position: absolute;
  left: 8rpx;
  bottom: 6rpx;
  width: 12rpx;
  height: 2rpx;
  background: #4338ca;
  border-radius: 999rpx;
  transform: rotate(-18deg);
}

.collection-row {
  background: #f8f7fe;
}

.collection-tag {
  min-width: 56rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e9e7ff;
  color: #5b21b6;
  font-size: 23rpx;
  font-weight: 500;
}

.tab-pill {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 72rpx;
  background: #ffffff;
}

.tab-pill-item {
  flex: 1;
  height: 54rpx;
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #667085;
  font-size: 23rpx;
  font-weight: 600;
}

.tab-pill-item-studio {
  font-size: 29rpx;
}

.tab-pill-item-assistant {
  font-size: 27rpx;
}

.tab-pill-item-user {
  font-size: 19rpx;
}

.tab-pill-item-active {
  background: #6366f1;
  color: #ffffff;
  font-size: 31rpx;
}

/* ===== 隐私协议弹窗 ===== */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 9000;
}

.privacy-modal {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(80rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 36rpx;
  z-index: 9001;
  box-shadow: 0 8rpx 48rpx rgba(0, 0, 0, 0.16);
}

.privacy-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 24rpx;
  letter-spacing: 0.5rpx;
}

.privacy-body {
  font-size: 27rpx;
  color: #374151;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.privacy-brand {
  font-weight: 600;
  color: #111827;
}

.privacy-link {
  color: #6366f1;
  font-weight: 500;
  text-decoration: underline;
}

.privacy-info {
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}

.privacy-info-item {
  font-size: 25rpx;
  color: #6b7280;
  line-height: 1.8;
}

.privacy-actions {
  display: flex;
  gap: 20rpx;
}

.privacy-btn-disagree {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-btn-agree {
  flex: 2;
  height: 88rpx;
  border-radius: 16rpx;
  background: #6366f1;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
