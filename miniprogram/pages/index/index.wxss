@import "/styles/pencil-theme.wxss";

.p-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% 8%, rgba(114, 107, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #f8f8ff 0%, #f3f5ff 60%, #eef1ff 100%);
  color: #111827;
}

.p-shell {
  padding: 0 24rpx calc(132rpx + env(safe-area-inset-bottom));
}

.p-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 36rpx rgba(114, 123, 174, 0.1);
}

.p-hero-card {
  background: linear-gradient(180deg, rgba(108, 99, 255, 0.14) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.p-hero-top,
.p-section-head,
.p-link-row,
.p-member-chip {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.p-hero-top {
  align-items: flex-start;
  gap: 20rpx;
}

.p-kicker {
  font-size: 18rpx;
  letter-spacing: 1.6rpx;
  color: #6d63ff;
}

.p-title {
  margin-top: 8rpx;
  font-size: 54rpx;
  line-height: 1.06;
  font-weight: 700;
  color: #111827;
}

.p-subtitle,
.p-link-desc,
.p-member-meta,
.p-section-meta {
  font-size: 22rpx;
  line-height: 1.4;
  color: #707998;
}

.p-member-chip {
  gap: 12rpx;
  padding: 14rpx 18rpx 14rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
}

.p-member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8eaff;
  color: #4338ca;
  font-size: 24rpx;
  font-weight: 700;
}

.p-member-tier,
.p-section-title,
.p-link-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2340;
}

.p-hero-tag {
  display: inline-flex;
  margin-top: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(92, 83, 235, 0.1);
  color: #4f46e5;
  font-size: 20rpx;
  font-weight: 700;
}

.p-hero-copy {
  margin-top: 18rpx;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #111827;
}

.p-primary-action {
  margin-top: 24rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5647ff 100%);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.p-section-head {
  gap: 16rpx;
}

.p-section-meta {
  font-size: 20rpx;
  text-align: right;
}

.p-link-row {
  margin-top: 18rpx;
  gap: 16rpx;
  padding: 20rpx 0 4rpx;
  border-top: 1rpx solid #eceffd;
}

.p-link-arrow {
  color: #6d63ff;
  font-size: 28rpx;
  font-weight: 700;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.42);
}

.privacy-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.2);
}

.privacy-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.privacy-body,
.privacy-info-item {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #4b5563;
}

.privacy-brand,
.privacy-link {
  color: #4f46e5;
  font-weight: 700;
}

.privacy-info {
  margin-top: 8rpx;
}

.privacy-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.privacy-btn-disagree,
.privacy-btn-agree {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.privacy-btn-disagree {
  background: #eef1ff;
  color: #4f46e5;
}

.privacy-btn-agree {
  background: linear-gradient(135deg, #7267ff 0%, #5647ff 100%);
  color: #ffffff;
}
