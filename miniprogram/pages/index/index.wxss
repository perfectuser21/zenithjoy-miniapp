@import "/styles/pencil-theme.wxss";

.home-page {
  min-height: 100vh;
  background: #f6f7fe;
  color: #111827;
}

.home-shell {
  padding: 0 20rpx calc(124rpx + env(safe-area-inset-bottom));
}

.home-head {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.home-head-text {
  flex: 1;
}

.home-title {
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #111827;
}

.home-hero-card,
.home-section-card {
  margin-top: 10rpx;
  overflow: hidden;
}

.home-hero-card {
  position: relative;
  min-height: 265rpx;
  border-radius: 35rpx;
}

.home-section-card {
  border-radius: 31rpx;
}

.home-hero-image {
  width: 100%;
  height: 265rpx;
  display: block;
}

.home-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(22, 33, 77, 0.08) 0%, rgba(16, 24, 40, 0.48) 100%);
}

.home-hero-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 23rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.home-hero-kicker {
  display: inline-flex;
  align-self: flex-start;
  padding: 12rpx 23rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  font-size: 31rpx;
  font-weight: 500;
  color: #4338ca;
  font-family: "IBM Plex Mono";
}

.home-hero-copy {
  max-width: 100%;
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.home-hero-desc {
  max-width: 100%;
  font-size: 21rpx;
  line-height: 1.3;
  color: rgba(255, 255, 255, 0.86);
}

.home-section-card {
  padding: 19rpx;
  background: #ffffff;
}

.home-creation-card {
  background: #f8f7fe;
}

.home-assist-card {
  padding: 15rpx;
}

.home-section-head,
.home-ranking-row,
.home-collection-row {
  display: flex;
  align-items: center;
}

.home-section-head,
.home-ranking-row,
.home-collection-row {
  justify-content: space-between;
}

.home-section-head-left {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.home-section-kicker {
  letter-spacing: 1.2rpx;
  font-weight: 500;
  font-family: "IBM Plex Mono";
}

.home-section-kicker-ranking {
  font-size: 17rpx;
  color: #4f46e5;
}

.home-section-kicker-create,
.home-section-kicker-assist {
  font-size: 13rpx;
}

.home-section-kicker-create {
  color: #6d28d9;
}

.home-section-kicker-assist {
  color: #4f46e5;
}

.home-section-meta {
  font-size: 23rpx;
  line-height: 1.3;
  color: #8b90a7;
}

.home-section-meta-create {
  color: #7c3aed;
  font-weight: 600;
}

.home-section-title {
  font-size: 35rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #101828;
}

.home-ranking-list,
.home-collection-list {
  margin-top: 12rpx;
}

.home-ranking-row,
.home-collection-row {
  gap: 12rpx;
  padding: 15rpx;
  border-radius: 19rpx;
  background: #eef1ff;
}

.home-ranking-row + .home-ranking-row,
.home-collection-row + .home-collection-row {
  margin-top: 10rpx;
}

.home-ranking-pill {
  min-width: 73rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: #6366f1;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 23rpx;
  font-weight: 500;
  color: #ffffff;
  font-family: "IBM Plex Mono";
}

.home-ranking-name,
.home-collection-title {
  flex: 1;
  line-height: 1.18;
  font-weight: 700;
  font-size: 27rpx;
  color: #111827;
}

.home-row-link {
  font-size: 23rpx;
  font-weight: 600;
  color: #4338ca;
}

.home-creation-grid {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.home-creation-item-blue {
  background: #dbeafe;
}

.home-creation-item-violet {
  background: #f3eeff;
}

.home-creation-item-indigo {
  background: #e9e7ff;
}

.home-creation-item {
  min-height: 115rpx;
  width: 100%;
  padding: 15rpx 54rpx 15rpx 15rpx;
  border-radius: 19rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  position: relative;
  box-sizing: border-box;
}

.home-creation-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 700;
}

.home-creation-item-blue .home-creation-icon {
  background: #bfdbfe;
  color: #1e40af;
}

.home-creation-item-violet .home-creation-icon {
  background: #e9d5ff;
  color: #6d28d9;
}

.home-creation-item-indigo .home-creation-icon {
  background: #ddd6fe;
  color: #4338ca;
}

.home-creation-item-title {
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #111827;
}

.home-creation-item-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.16;
}

.home-creation-item-blue .home-creation-item-desc {
  color: #5b6b8a;
}

.home-creation-item-violet .home-creation-item-desc {
  color: #7c3aed;
}

.home-creation-item-indigo .home-creation-item-desc {
  color: #5b21b6;
}

.home-collection-row {
  background: #f8f7fe;
}

.home-collection-index {
  width: 69rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: #e9e7ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "IBM Plex Mono";
  font-size: 23rpx;
  font-weight: 500;
  color: #5b21b6;
}

.privacy-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.42);
}

.privacy-modal {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(48rpx + env(safe-area-inset-bottom));
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.2);
}

.privacy-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.privacy-body,
.privacy-info-item {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.5;
  color: #4b5563;
}

.privacy-brand,
.privacy-link {
  color: #4f46e5;
  font-weight: 700;
}

.privacy-info {
  margin-top: 8rpx;
}

.privacy-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.privacy-btn-disagree,
.privacy-btn-agree {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.privacy-btn-disagree {
  background: #eef1ff;
  color: #4f46e5;
}

.privacy-btn-agree {
  background: linear-gradient(135deg, #7267ff 0%, #5647ff 100%);
  color: #ffffff;
}
