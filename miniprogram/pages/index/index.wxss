.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 15% 8%, rgba(127, 109, 255, 0.16), transparent 28%),
    radial-gradient(circle at 84% 10%, rgba(98, 156, 255, 0.14), transparent 30%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef2ff 100%);
  color: #111827;
  padding: 0 32rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  padding-bottom: 10rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.eyebrow {
  font-size: 22rpx;
  color: #4f46e5;
  letter-spacing: 1.2rpx;
  margin-bottom: 12rpx;
}

.build-badge {
  display: inline-block;
  margin-bottom: 10rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.page-title {
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #111827;
}

.hero-chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 16rpx 10rpx 10rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 10rpx 24rpx rgba(98, 110, 180, 0.08);
}

.hero-chip-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #e8eaff;
  color: #4338ca;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-chip-copy {
  display: flex;
  flex-direction: column;
}

.hero-chip-title {
  font-size: 17rpx;
  color: #667085;
  line-height: 1.2;
}

.hero-chip-meta {
  margin-top: 4rpx;
  font-size: 17rpx;
  color: #4338ca;
  font-weight: 600;
  line-height: 1.2;
}

.hero-banner {
  position: relative;
  height: 280rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(102, 104, 170, 0.16);
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(17, 24, 39, 0.75) 0%, rgba(17, 24, 39, 0.2) 100%);
}

.hero-banner-content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-badge {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 18rpx;
  align-self: flex-start;
}

.hero-banner-title {
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.hero-banner-desc {
  font-size: 18rpx;
  line-height: 1.3;
  color: #f5f3ff;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.section {
  margin-top: 10rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(110, 113, 187, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(122, 132, 178, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.section-kicker {
  font-size: 18rpx;
  letter-spacing: 1.2rpx;
  color: #4f46e5;
  margin-bottom: 4rpx;
}

.section-title {
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #111827;
}

.section-link {
  font-size: 18rpx;
  color: #667085;
  font-weight: 600;
}

.rank-kicker {
  font-size: 17rpx;
}

.rank-title {
  font-size: 27rpx;
}

.rank-link {
  font-size: 19rpx;
}

.create-kicker,
.collection-kicker {
  font-size: 13rpx;
}

.create-title,
.collection-head-title {
  font-size: 23rpx;
}

.create-link,
.collection-head-link {
  font-size: 15rpx;
}

.ranking-list,
.collection-list,
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ranking-item,
.collection-item,
.recent-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #eef1ff;
  gap: 14rpx;
}

.ranking-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.ranking-index,
.collection-index,
.recent-mark {
  min-width: 76rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #6366f1;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 500;
  margin-right: 0;
}

.ranking-title,
.collection-title,
.recent-title {
  line-height: 1.25;
  color: #1f2937;
  font-weight: 700;
}

.ranking-action,
.collection-link,
.recent-link {
  font-size: 17rpx;
  color: #4338ca;
  font-weight: 600;
}

.ranking-title-primary {
  font-size: 20rpx;
}

.ranking-title-secondary {
  font-size: 20rpx;
}

.tool-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tool-card {
  width: calc((100% - 10rpx) / 2);
  min-height: 112rpx;
  padding: 16rpx 56rpx 16rpx 16rpx;
  border-radius: 20rpx;
  background: #dbeafe;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
}

.tool-card-primary {
  background: linear-gradient(180deg, #6366f1 0%, #8b5cf6 100%);
}

.tool-card-top {
  display: block;
  margin-bottom: 6rpx;
}

.tool-card-title {
  font-size: 21rpx;
  line-height: 1.2;
  color: #0f172a;
  font-weight: 700;
}

.tool-card-primary .tool-card-title,
.tool-card-primary .tool-card-desc,
.tool-card-primary .tool-card-icon {
  color: #ffffff;
}

.tool-card-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #4f46e5;
  background: rgba(255, 255, 255, 0.56);
}

.tool-card-desc {
  font-size: 15rpx;
  line-height: 1.2;
  color: #5b6b8a;
}

.collection-main,
.recent-body {
  flex: 1;
  min-width: 0;
}

.collection-item,
.recent-item {
  align-items: flex-start;
  background: #f8f7fe;
}

.collection-title,
.collection-desc,
.recent-title,
.recent-desc {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
}

.collection-title,
.recent-title {
  -webkit-line-clamp: 2;
}

.collection-title-primary {
  font-size: 20rpx;
  line-height: 1.22;
}

.collection-title-secondary,
.recent-title {
  font-size: 20rpx;
}

.collection-desc,
.recent-desc {
  margin-top: 4rpx;
  font-size: 15rpx;
  line-height: 1.3;
  color: #7d86a4;
  -webkit-line-clamp: 1;
}

.safe-bottom {
  height: 8rpx;
}

.emergency-container {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.92);
}

.emergency-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 40rpx;
}

.emergency-text {
  color: #111827;
  font-size: 28rpx;
}

.emergency-btn {
  background: #6c63ff;
  color: #ffffff;
}
