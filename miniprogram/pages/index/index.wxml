<view class="home-page">
  <view class="home-shell" style="padding-top: {{statusBarHeight + 8}}px;">
    <view class="home-head">
      <view class="home-head-text">
        <view class="home-title">{{homeTitle}}</view>
      </view>
    </view>

    <view class="home-hero-card" bindtap="openWorkflowHub">
      <image class="home-hero-image" src="{{heroCard.image}}" mode="aspectFill"></image>
      <view class="home-hero-overlay"></view>
      <view class="home-hero-content">
        <view class="home-hero-kicker">{{heroCard.tag}}</view>
        <view class="home-hero-copy">{{heroCard.titleTop}}</view>
        <view class="home-hero-desc">{{heroCard.description}}</view>
      </view>
    </view>

    <view class="home-section-card home-ranking-card">
      <view class="home-section-head">
          <view class="home-section-head-left">
              <view class="home-section-kicker home-section-kicker-ranking">TODAY RANKING</view>
              <view class="home-section-title">今日榜单</view>
            </view>
        <view class="home-section-meta">实时更新</view>
      </view>
      <view class="home-ranking-list">
        <view
          class="home-ranking-row"
          wx:for="{{rankingItems}}"
          wx:key="title"
          bindtap="openRankingDetail"
        >
          <view class="home-ranking-pill">{{item.tag}}</view>
          <view class="home-ranking-name">{{item.title}}</view>
          <view class="home-row-link">查看</view>
        </view>
      </view>
    </view>

    <view class="home-section-card home-creation-card">
      <view class="home-section-head">
          <view class="home-section-head-left">
              <view class="home-section-kicker home-section-kicker-create">MEDIA CREATION</view>
              <view class="home-section-title">{{creationEntry.title}}</view>
            </view>
        <view class="home-section-meta home-section-meta-create">{{creationEntry.description}}</view>
      </view>
      <view class="home-creation-grid">
        <view
          class="home-creation-item home-creation-item-{{item.layout}} home-creation-item-{{item.tone}}"
          wx:for="{{creationCards}}"
          wx:key="title"
          bindtap="openCreationHub"
        >
          <view class="home-creation-icon">{{item.icon}}</view>
          <view class="home-creation-item-title">{{item.title}}</view>
          <view class="home-creation-item-desc">{{item.description}}</view>
        </view>
      </view>
    </view>

    <view class="home-section-card home-assist-card">
      <view class="home-section-head">
          <view class="home-section-head-left">
              <view class="home-section-kicker home-section-kicker-assist">CREATOR COLLECTION</view>
              <view class="home-section-title">自媒体前沿创作集</view>
            </view>
            <view class="home-section-meta">精选文章</view>
          </view>
      <view class="home-collection-list">
        <view
          class="home-collection-row"
          wx:for="{{collectionItems}}"
          wx:key="index"
          bindtap="openReadingDetail"
        >
          <view class="home-collection-index">{{item.index}}</view>
          <view class="home-collection-title">{{item.title}}</view>
          <view class="home-row-link">查看</view>
        </view>
      </view>
    </view>
  </view>

  <view class="privacy-mask" wx:if="{{showPrivacy}}" catchtap="disagreePrivacy"></view>
  <view class="privacy-modal" wx:if="{{showPrivacy}}">
    <view class="privacy-title">用户隐私保护提示</view>
    <view class="privacy-body">
      感谢您使用 <text class="privacy-brand">ZenithJoy</text>。在使用本小程序前，请阅读并同意我们的
      <text class="privacy-link" bindtap="openPrivacyPage">《用户隐私协议》</text>，我们将按照协议保护您的个人信息。
    </view>
    <view class="privacy-info">
      <view class="privacy-info-item">· 微信昵称、头像：用于展示您的会员身份</view>
      <view class="privacy-info-item">· 位置信息：仅在您主动使用相关功能时采集</view>
    </view>
    <view class="privacy-actions">
      <button class="privacy-btn-disagree" bindtap="disagreePrivacy">不同意</button>
      <button class="privacy-btn-agree" id="agree-btn" bindtap="agreePrivacy">同意并继续</button>
    </view>
  </view>
</view>
