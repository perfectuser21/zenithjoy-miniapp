<view class="page">
  <view class="page-shell" style="padding-top: {{statusBarHeight + 20}}px;">
    <view class="head">
      <view class="head-copy">
        <view class="head-kicker">AI 自媒体小程序</view>
        <view class="head-title">今天先做什么</view>
      </view>
      <view class="user-entry" bindtap="openMembership">
        <view class="user-avatar">{{memberInitial}}</view>
        <view class="user-meta">
          <view class="user-tier">{{memberTier}}</view>
          <view class="user-streak">连续打卡 {{streakDays}} 天</view>
        </view>
      </view>
    </view>

    <view class="hero-card" bindtap="openAIChat" data-id="expert">
      <image class="hero-image" src="{{heroCard.image}}" mode="aspectFill"></image>
      <view class="hero-mask"></view>
      <view class="hero-chip">{{heroCard.tag}}</view>
      <view class="hero-copy">
        <view class="hero-title">{{heroCard.titleTop}}</view>
        <view class="hero-title">{{heroCard.titleBottom}}</view>
        <view class="hero-desc">{{heroCard.description}}</view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-head-copy">
          <view class="panel-kicker panel-kicker-ranking">TODAY RANKING</view>
          <view class="panel-title">今日榜单</view>
        </view>
        <view class="panel-hint panel-hint-muted">实时更新</view>
      </view>
      <view
        class="rank-row"
        wx:for="{{rankingItems}}"
        wx:key="title"
        bindtap="handleAction"
        data-type="{{item.actionType}}"
        data-target="{{item.actionTarget}}"
      >
        <view class="rank-tag">{{item.tag}}</view>
        <view class="rank-title">{{item.title}}</view>
        <view class="rank-link">查看</view>
      </view>
    </view>

    <view class="panel panel-creation">
      <view class="panel-head">
        <view class="panel-head-copy">
          <view class="panel-kicker panel-kicker-creation panel-kicker-purple">MEDIA CREATION</view>
          <view class="panel-title">自媒体创作区域</view>
        </view>
        <view class="panel-hint panel-hint-purple">常用工具</view>
      </view>

      <view class="tool-grid">
        <view
          class="tool-card {{item.cardClass}}"
          wx:for="{{creationTools}}"
          wx:key="title"
          bindtap="handleAction"
          data-type="{{item.actionType}}"
          data-target="{{item.actionTarget}}"
        >
          <view class="tool-icon-box {{item.iconBoxClass}}">
            <view wx:if="{{item.iconType === 'target'}}" class="tool-icon-target">
              <view class="target-ring target-ring-outer"></view>
              <view class="target-ring target-ring-inner"></view>
              <view class="target-dot"></view>
              <view class="target-line target-line-horizontal"></view>
              <view class="target-line target-line-vertical"></view>
            </view>
            <view wx:elif="{{item.iconType === 'pen'}}" class="tool-icon-pen">
              <view class="pen-body"></view>
              <view class="pen-tip"></view>
              <view class="pen-cut"></view>
            </view>
            <view wx:elif="{{item.iconType === 'sparkles'}}" class="tool-icon-sparkles">
              <view class="sparkle-ray sparkle-ray-vertical"></view>
              <view class="sparkle-ray sparkle-ray-horizontal"></view>
              <view class="sparkle-ray sparkle-ray-diagonal-a"></view>
              <view class="sparkle-ray sparkle-ray-diagonal-b"></view>
              <view class="sparkle-core"></view>
            </view>
            <view wx:else class="tool-icon-send">
              <view class="send-outline"></view>
              <view class="send-tail"></view>
            </view>
          </view>
          <view class="tool-title">{{item.title}}</view>
          <view class="tool-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>

    <view class="panel">
      <view class="panel-head">
        <view class="panel-head-copy">
          <view class="panel-kicker panel-kicker-collection">CREATOR COLLECTION</view>
          <view class="panel-title">自媒体前沿创作集</view>
        </view>
        <view class="panel-hint panel-hint-muted">精选文章</view>
      </view>
      <view
        class="collection-row"
        wx:for="{{collectionItems}}"
        wx:key="index"
        bindtap="handleAction"
        data-type="{{item.actionType}}"
        data-target="{{item.actionTarget}}"
      >
        <view class="collection-tag">{{item.index}}</view>
        <view class="collection-title">{{item.title}}</view>
        <view class="collection-link">查看</view>
      </view>
    </view>

  </view>

  <!-- 隐私协议弹窗（微信审核要求）-->
  <view class="privacy-mask" wx:if="{{showPrivacy}}" catchtap="disagreePrivacy"></view>
  <view class="privacy-modal" wx:if="{{showPrivacy}}">
    <view class="privacy-title">用户隐私保护提示</view>
    <view class="privacy-body">
      感谢您使用 <text class="privacy-brand">ZenithJoy</text>。在使用本小程序前，请阅读并同意我们的
      <text class="privacy-link" bindtap="openPrivacyPage">《用户隐私协议》</text>，我们将按照协议保护您的个人信息。
    </view>
    <view class="privacy-info">
      <view class="privacy-info-item">· 微信昵称、头像：用于展示您的会员身份</view>
      <view class="privacy-info-item">· 位置信息：仅在您主动使用相关功能时采集</view>
    </view>
    <view class="privacy-actions">
      <button class="privacy-btn-disagree" bindtap="disagreePrivacy">不同意</button>
      <button class="privacy-btn-agree" id="agree-btn" bindtap="agreePrivacy">同意并继续</button>
    </view>
  </view>
</view>
