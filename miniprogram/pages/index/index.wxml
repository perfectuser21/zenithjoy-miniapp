<view class="p-page">
  <view class="p-shell" style="padding-top: {{statusBarHeight + 16}}px;">
    <view class="p-card p-hero-card">
      <view class="p-hero-top">
        <view>
          <view class="p-kicker">HOME</view>
          <view class="p-title">今天先跑主流程</view>
        </view>
        <view class="p-member-chip" bindtap="openMembership">
          <view class="p-member-avatar">{{memberInitial}}</view>
          <view>
            <view class="p-member-tier">{{memberTier}}</view>
            <view class="p-member-meta">连续 {{streakDays}} 天</view>
          </view>
        </view>
      </view>
      <view class="p-hero-tag">{{heroCard.tag}}</view>
      <view class="p-hero-copy">{{heroCard.titleTop}}{{heroCard.titleBottom}}</view>
      <view class="p-subtitle">{{heroCard.description}}</view>
      <view class="p-primary-action" bindtap="openCopywriterStart">进入文案流程</view>
    </view>

    <view class="p-card">
      <view class="p-section-head">
        <view class="p-section-title">今日榜单</view>
        <view class="p-section-meta">正式详情入口</view>
      </view>
      <view class="p-link-row" bindtap="openRankingDetail">
        <view>
          <view class="p-link-title">查看榜单详情</view>
          <view class="p-link-desc">热点、低粉爆款和涨粉榜统一进入榜单详情。</view>
        </view>
        <view class="p-link-arrow">></view>
      </view>
    </view>

    <view class="p-card">
      <view class="p-section-head">
        <view class="p-section-title">创作精选</view>
        <view class="p-section-meta">Pencil 正式入口</view>
      </view>
      <view class="p-link-row" bindtap="openReadingDetail">
        <view>
          <view class="p-link-title">查看前沿创作集</view>
          <view class="p-link-desc">首页只保留精选内容入口，不再回到旧文章列表。</view>
        </view>
        <view class="p-link-arrow">></view>
      </view>
    </view>
  </view>

  <view class="privacy-mask" wx:if="{{showPrivacy}}" catchtap="disagreePrivacy"></view>
  <view class="privacy-modal" wx:if="{{showPrivacy}}">
    <view class="privacy-title">用户隐私保护提示</view>
    <view class="privacy-body">
      感谢您使用 <text class="privacy-brand">ZenithJoy</text>。在使用本小程序前，请阅读并同意我们的
      <text class="privacy-link" bindtap="openPrivacyPage">《用户隐私协议》</text>，我们将按照协议保护您的个人信息。
    </view>
    <view class="privacy-info">
      <view class="privacy-info-item">· 微信昵称、头像：用于展示您的会员身份</view>
      <view class="privacy-info-item">· 位置信息：仅在您主动使用相关功能时采集</view>
    </view>
    <view class="privacy-actions">
      <button class="privacy-btn-disagree" bindtap="disagreePrivacy">不同意</button>
      <button class="privacy-btn-agree" id="agree-btn" bindtap="agreePrivacy">同意并继续</button>
    </view>
  </view>
</view>
