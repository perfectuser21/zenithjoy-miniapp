/* pages/article/preview.wxss */
.container {
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 84% 10%, rgba(122, 109, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.article-header {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.article-title {
  font-size: 42rpx;
  font-weight: bold;
  line-height: 1.4;
  margin-bottom: 20rpx;
  color: #1f2937;
}

.article-meta {
  display: flex;
  font-size: 26rpx;
  color: #8f95af;
  margin-bottom: 20rpx;
}

.article-author {
  margin-right: 20rpx;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #5a4cff;
  background-color: #eef0ff;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.article-cover {
  margin-bottom: 24rpx;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.article-cover image {
  width: 100%;
  border-radius: 28rpx;
}

.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #1f2937;
  margin-bottom: 24rpx;
  text-align: justify;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
  white-space: pre-wrap;
}

.article-stats {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.9);
}

.stat-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #8f95af;
}

.preview-tips {
  text-align: center;
  font-size: 26rpx;
  color: #ff9500;
  background-color: #fff9f0;
  padding: 24rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: white;
  text-align: center;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.loading {
  font-size: 28rpx;
  color: #8f95af;
}
