<view class="p-page">
  <view class="p-shell" style="padding-top: {{statusBarHeight}}px;">
    <view class="user-head">
      <view class="user-head-left">
        <view class="user-kicker">{{pageEyebrow}}</view>
        <view class="user-title">{{pageTitle}}</view>
      </view>
    </view>

    <view class="user-card user-profile-card" wx:if="{{showProfileCard}}">
      <view class="user-profile-row">
        <view class="user-avatar">{{avatarInitials}}</view>
        <view class="user-profile-copy">
          <view class="user-profile-name">{{profileName}}</view>
          <view class="user-profile-sub">{{profileStage}} · {{membership.name}}</view>
        </view>
      </view>
    </view>

    <view class="user-card">
      <view class="user-section-head">
        <view class="user-section-title">积分中心</view>
        <view class="user-section-meta">查看明细</view>
      </view>
      <view class="user-points-panel">
        <view class="user-points-left">
          <view class="user-points-label">当前积分</view>
          <view class="user-points-value">{{points}}</view>
        </view>
        <view class="user-points-right">
          <view class="user-points-growth">本周 +{{weeklyGrowth}}</view>
          <view class="user-points-spend">本周消耗 {{monthlySpend}}</view>
        </view>
      </view>
      <view class="user-points-actions">
        <view class="user-points-chip">
          <view class="user-chip-title">积分获取</view>
          <view class="user-chip-desc">签到 / 推荐 / 问答</view>
        </view>
        <view class="user-points-chip">
          <view class="user-chip-title">积分消耗</view>
          <view class="user-chip-desc">标题 / 文案 / 助理</view>
        </view>
      </view>
    </view>

    <view class="user-card">
      <view class="user-section-head">
        <view class="user-section-title">会员与成长</view>
        <view class="user-section-accent">{{membership.name}}</view>
      </view>
      <view class="user-benefit-row" wx:for="{{growthBenefits}}" wx:key="title">
        <view class="user-benefit-title">{{item.title}}</view>
        <view class="user-benefit-status">{{item.status}}</view>
      </view>
    </view>

    <view class="user-card">
      <view class="user-section-head">
        <view class="user-section-title user-section-title-small">最近活跃</view>
        <view class="user-section-meta">本周</view>
      </view>
      <view class="user-recent-row" wx:for="{{recentActivities}}" wx:key="title">
        <view class="user-recent-title">{{item.title}}</view>
        <view class="user-recent-value">{{item.value}}</view>
      </view>
    </view>
  </view>
</view>
