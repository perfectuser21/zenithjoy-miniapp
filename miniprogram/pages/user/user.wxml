<view class="p-page">
  <view class="p-shell" style="padding-top: {{statusBarHeight + 16}}px;">
    <view class="p-card p-hero-card" wx:if="{{showProfileCard}}">
      <view class="p-kicker">MY CENTER</view>
      <view class="p-title">我的</view>
      <view class="p-profile-row">
        <view class="p-avatar">{{avatarInitials}}</view>
        <view class="p-profile-copy">
          <view class="p-profile-name">{{profileName}}</view>
          <view class="p-subtitle">{{profileStage}} · {{membership.name}}</view>
        </view>
      </view>
    </view>

    <view class="p-card">
      <view class="p-section-head">
        <view class="p-section-title">积分与会员</view>
        <view class="p-section-meta">当前积分 {{points}}</view>
      </view>
      <view class="p-link-row" bindtap="openMembership">
        <view>
          <view class="p-link-title">进入会员中心</view>
          <view class="p-link-desc">查看权益、积分明细与升级状态。</view>
        </view>
        <view class="p-link-arrow">></view>
      </view>
      <view class="p-link-row" bindtap="openTaskCenter">
        <view>
          <view class="p-link-title">查看任务中心</view>
          <view class="p-link-desc">继续历史对话与任务产出。</view>
        </view>
        <view class="p-link-arrow">></view>
      </view>
      <view class="p-link-row" bindtap="clearCache">
        <view>
          <view class="p-link-title">清除本地缓存</view>
          <view class="p-link-desc">重置登录信息与本地历史缓存。</view>
        </view>
        <view class="p-link-arrow">></view>
      </view>
      <view class="p-link-row" wx:if="{{isAdmin}}" bindtap="openAdminCenter">
        <view>
          <view class="p-link-title">进入管理中心</view>
          <view class="p-link-desc">仅管理员可见。</view>
        </view>
        <view class="p-link-arrow">></view>
      </view>
    </view>
  </view>
</view>
