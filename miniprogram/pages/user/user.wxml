<view class="page">
  <view class="top" style="padding-top: {{statusBarHeight + 12}}px;">
    <view class="eyebrow">MY CENTER</view>
    <view class="title-row">
      <view class="title">我的</view>
      <view class="section-link">编辑资料</view>
    </view>
  </view>

  <view class="profile-card" wx:if="{{showProfileCard}}">
    <view class="avatar-badge">{{avatarInitials}}</view>
    <view class="profile-main">
      <view class="profile-name">{{profileName}}</view>
      <view class="profile-subtitle">{{profileStage}} · {{membership.name}}</view>
    </view>
  </view>

  <view class="points-section">
    <view class="section-head">
      <view class="section-title">积分中心</view>
      <view class="section-link">查看明细</view>
    </view>
    <view class="points-card">
      <view class="points-label">当前积分</view>
      <view class="points-top">
        <view class="points-value">{{points}}</view>
        <view class="points-growth">
          <view class="points-growth-value">本周 +{{weeklyGrowth}}</view>
          <view class="points-growth-meta">本月消耗 {{monthlySpend}}</view>
        </view>
      </view>
      <view class="points-stats">
        <view class="points-stat">
          <view class="points-stat-title">积分获取</view>
          <view class="points-stat-desc">签到 / 提问 / 问答</view>
        </view>
        <view class="points-stat">
          <view class="points-stat-title">积分消耗</view>
          <view class="points-stat-desc">标题 / 文案 / 助理</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <view class="section-title">会员与成长</view>
      <view class="section-link">{{membership.name}}</view>
    </view>
    <view class="growth-list">
      <view class="growth-item" wx:for="{{growthBenefits}}" wx:key="title">
        <view class="growth-name">{{item.title}}</view>
        <view class="growth-status">{{item.status}}</view>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="menu-list">
      <view class="menu-item" wx:for="{{assetMenus}}" wx:key="id" bindtap="handleAssetAction" data-id="{{item.id}}">
        <view class="menu-text">{{item.title}}</view>
        <view class="menu-arrow">></view>
      </view>
      <view class="menu-item" wx:if="{{isAdmin}}" bindtap="navigateToAdmin">
        <view class="menu-text">管理中心</view>
        <view class="menu-arrow">></view>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <view class="section-title">最近活跃</view>
      <view class="section-meta">本周</view>
    </view>
    <view class="activity-list">
      <view class="activity-item" wx:for="{{recentActivities}}" wx:key="title">
        <view class="activity-title">{{item.title}}</view>
        <view class="activity-value">{{item.value}}</view>
      </view>
    </view>
  </view>
</view>
