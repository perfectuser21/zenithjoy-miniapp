<!--pages/user/user.wxml-->
<view class="container">
  <view class="hero-section">
    <view class="hero-glow hero-glow-top"></view>
    <view class="hero-glow hero-glow-bottom"></view>

    <view class="hero-card" wx:if="{{!hasUserInfo && canIUseGetUserProfile}}">
      <view class="avatar-row">
        <view class="avatar-wrapper">
          <image class="avatar" src="/images/default-avatar.png"></image>
        </view>
        <view class="user-info">
          <view class="nickname">登录后开启你的 AI 一人公司</view>
          <view class="hero-subtitle">保存积分、体验版权益和经营记录。</view>
        </view>
      </view>
      <view class="hero-actions">
        <button class="primary-button" bindtap="startLogin">微信一键登录</button>
      </view>
    </view>

    <view class="hero-card" wx:else>
      <view class="avatar-row">
        <view class="avatar-wrapper">
          <image class="avatar" src="{{hasUserInfo ? userInfo.avatarUrl : '/images/default-avatar.png'}}"></image>
        </view>
        <view class="user-info">
          <view class="nickname">{{hasUserInfo ? userInfo.nickName : '点击登录'}}</view>
          <view class="member-tag {{membership.level === 'premium' ? 'vip' : (membership.level === 'standard' ? 'standard' : '')}}">
            {{membership.name || '普通会员'}}
          </view>
          <view class="hero-subtitle">{{profileStage}}</view>
          <view class="phone-info" wx:if="{{phoneNumber}}">
            <text class="phone-text">{{phoneNumber}}</text>
          </view>
          <view class="phone-btn-container" wx:else>
            <button class="phone-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber">绑定手机号</button>
          </view>
        </view>
      </view>
      <view class="stats-grid">
        <view class="stat-card" wx:for="{{growthStats}}" wx:key="label">
          <view class="stat-value">{{item.value}}</view>
          <view class="stat-label">{{item.label}}</view>
        </view>
      </view>
    </view>
  </view>

  <button class="hidden-btn" open-type="getPhoneNumber" bindgetphonenumber="getPhoneNumber" id="phoneBtn"></button>

  <view class="content">
    <view class="section-title">我的资产</view>
    <view class="menu-list">
      <view class="menu-item card-style" wx:for="{{assetMenus}}" wx:key="id" bindtap="handleAssetAction" data-id="{{item.id}}">
        <view class="menu-icon">{{item.icon}}</view>
        <view class="menu-content">
          <view class="menu-text">{{item.title}}</view>
          <view class="menu-desc">{{item.desc}}</view>
        </view>
        <view class="menu-arrow">继续</view>
      </view>
      <view class="menu-item card-style" bindtap="navigateToAdmin" wx:if="{{isAdmin}}">
        <view class="menu-icon">后台</view>
        <view class="menu-content">
          <view class="menu-text">管理中心</view>
          <view class="menu-desc">文章管理与内部配置入口</view>
        </view>
        <view class="menu-arrow">进入</view>
      </view>
    </view>

    <view class="section-title">体验版须知</view>
    <view class="notice-card">
      <view class="notice-title">当前账号定位</view>
      <view class="notice-text">你现在以体验成员身份查看小程序，推荐先看首页、工作流聊天页和积分权益页。</view>
      <view class="notice-tags">
        <view class="notice-chip">体验成员已开通</view>
        <view class="notice-chip">适合快速验收</view>
      </view>
    </view>

    <view class="section-title">更多操作</view>
    <view class="menu-list">
      <view class="menu-item card-style" wx:for="{{supportMenus}}" wx:key="id" bindtap="handleSupportAction" data-id="{{item.id}}">
        <view class="menu-icon">{{item.icon}}</view>
        <view class="menu-content">
          <view class="menu-text">{{item.title}}</view>
          <view class="menu-desc">{{item.desc}}</view>
        </view>
        <view class="menu-arrow">处理</view>
      </view>
    </view>
  </view>

  <view class="footer">
    <view class="footer-text">ZenithJoy · Member Center Beta</view>
  </view>
</view>
