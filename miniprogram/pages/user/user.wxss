.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 85% 10%, rgba(122, 109, 255, 0.12), transparent 26%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
  padding: 0 32rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.eyebrow {
  font-size: 24rpx;
  color: #6d63ff;
  margin-bottom: 6rpx;
}

.title-row,
.section-head,
.points-top,
.growth-item,
.menu-item,
.activity-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 60rpx;
  line-height: 1.04;
  font-weight: 700;
  color: #111827;
}

.profile-card,
.points-card,
.section-block {
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.profile-card {
  display: flex;
  align-items: center;
}

.avatar-badge {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.profile-main {
  flex: 1;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.profile-subtitle {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #7a7e9a;
  font-weight: 600;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2340;
}

.section-link,
.section-meta {
  font-size: 26rpx;
  color: #7a7e9a;
  font-weight: 600;
}

.points-label {
  font-size: 26rpx;
  color: #6b7291;
  font-weight: 600;
}

.points-value {
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #4e46d8;
  margin-top: 4rpx;
}

.points-growth {
  text-align: right;
}

.points-growth-value {
  font-size: 26rpx;
  color: #16a34a;
  font-weight: 700;
}

.points-growth-meta {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #7a7e9a;
  font-weight: 600;
}

.points-stats {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 12rpx;
}

.points-stat {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #eef4ff;
  border-radius: 20rpx;
}

.points-stat-title {
  font-size: 26rpx;
  color: #4362c4;
  font-weight: 700;
}

.points-stat-desc {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #6e7faf;
  font-weight: 600;
}

.growth-list,
.menu-list,
.activity-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.growth-item,
.menu-item,
.activity-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef1f8;
}

.growth-item:last-child,
.menu-item:last-child,
.activity-item:last-child {
  border-bottom: 0;
}

.growth-name,
.menu-text,
.activity-title {
  font-size: 28rpx;
  color: #2d3553;
  font-weight: 600;
}

.growth-status {
  font-size: 24rpx;
  color: #5a52d6;
  font-weight: 700;
}

.menu-arrow {
  color: #98a1bd;
  font-size: 28rpx;
  font-weight: 700;
}

.activity-value {
  font-size: 26rpx;
  color: #16a34a;
  font-weight: 700;
}
