@import "/styles/pencil-theme.wxss";

.p-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 85% 10%, rgba(122, 109, 255, 0.12), transparent 26%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.p-shell {
  padding: 0 32rpx calc(144rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.p-card {
  margin-top: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.p-hero-card {
  background: linear-gradient(180deg, rgba(108, 99, 255, 0.14) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.p-section-head,
.p-link-row,
.p-profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.p-kicker {
  font-size: 19rpx;
  color: #6d63ff;
  letter-spacing: 1.4rpx;
}

.p-title {
  margin-top: 8rpx;
  font-size: 58rpx;
  line-height: 1.04;
  font-weight: 700;
  color: #111827;
}

.p-profile-row {
  justify-content: flex-start;
  gap: 20rpx;
  margin-top: 18rpx;
}

.p-avatar {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.p-profile-copy {
  flex: 1;
}

.p-profile-name,
.p-section-title,
.p-link-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #1d2340;
}

.p-subtitle,
.p-section-meta,
.p-link-desc {
  margin-top: 4rpx;
  font-size: 21rpx;
  color: #7a7e9a;
  font-weight: 600;
}

.p-link-row {
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef1f8;
}

.p-link-row:last-child {
  border-bottom: 0;
}

.p-link-arrow {
  color: #98a1bd;
  font-size: 23rpx;
  font-weight: 700;
}
