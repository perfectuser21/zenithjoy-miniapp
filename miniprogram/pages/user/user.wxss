/* pages/user/user.wxss */
.container {
  padding: 0 0 40rpx 0;
  background:
    radial-gradient(circle at top right, rgba(242, 200, 141, 0.28), transparent 28%),
    linear-gradient(180deg, #f4eee6 0%, #f8f5ef 38%, #fbfaf7 100%);
  min-height: 100vh;
}

.hero-section {
  position: relative;
  padding: 36rpx 24rpx 18rpx;
  overflow: hidden;
}

.hero-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(12rpx);
}

.hero-glow-top {
  width: 300rpx;
  height: 300rpx;
  top: -80rpx;
  right: -60rpx;
  background: rgba(180, 110, 57, 0.16);
}

.hero-glow-bottom {
  width: 240rpx;
  height: 240rpx;
  left: -80rpx;
  top: 180rpx;
  background: rgba(29, 61, 54, 0.12);
}

.hero-card {
  position: relative;
  z-index: 1;
  padding: 30rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(92, 71, 56, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(71, 50, 34, 0.08);
}

.avatar-row {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  overflow: hidden;
  margin-right: 30rpx;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 4rpx solid rgba(255, 255, 255, 0.7);
}

.avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #241914;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: #726255;
  margin-top: 10rpx;
}

.hero-actions {
  margin-top: 26rpx;
}

.primary-button {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background-color: #1d1a17;
  color: #f9f1e8;
  font-size: 26rpx;
  border-radius: 28rpx;
  margin: 0;
}

.member-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #766558;
  background: rgba(242, 237, 229, 0.95);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  margin-top: 8rpx;
}

.phone-info {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #6a5a4e;
}

.phone-text {
  display: inline-block;
  padding: 2rpx 0;
}

.phone-btn-container {
  margin-top: 16rpx;
}

.phone-btn {
  font-size: 22rpx;
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #24453f;
  border: 1rpx solid rgba(36, 69, 63, 0.2);
  border-radius: 999rpx;
}

.phone-btn::after {
  border: none;
}

.vip {
  color: #ff9c00;
  background: #ffefd7;
}

.member-tag.vip {
  background-color: #FFD700;
  color: #8B4513;
}

.member-tag.standard {
  background-color: #87CEEB;
  color: #104E8B;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 26rpx;
}

.stat-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(245, 241, 234, 0.95);
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #241914;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  color: #7f6c5d;
  line-height: 1.4;
}

.content {
  padding: 0 24rpx;
}

.section-title {
  padding: 28rpx 6rpx 18rpx;
  font-size: 28rpx;
  color: #7d6d61;
  font-weight: 600;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.card-style {
  background-color: rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  border: 1rpx solid rgba(92, 71, 56, 0.08);
  box-shadow: 0 16rpx 36rpx rgba(72, 52, 37, 0.06);
}

.menu-content {
  flex: 1;
}

.menu-icon {
  min-width: 78rpx;
  height: 78rpx;
  padding: 0 12rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #f7efe5;
  background: #1d3d36;
  border-radius: 24rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #281e19;
  font-weight: 700;
}

.menu-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b685b;
}

.menu-arrow {
  color: #21423c;
  font-size: 22rpx;
  font-weight: 600;
}

.notice-card {
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(255, 245, 231, 0.96) 0%, rgba(243, 237, 228, 0.94) 100%);
  border: 1rpx solid rgba(92, 71, 56, 0.08);
  box-shadow: 0 16rpx 36rpx rgba(72, 52, 37, 0.06);
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #241a15;
  margin-bottom: 12rpx;
}

.notice-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b5a4f;
}

.notice-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.notice-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  color: #6e5d51;
  font-size: 22rpx;
}

.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #99887d;
}

.hidden-btn {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
  padding: 0;
  margin: 0;
  overflow: hidden;
}
