.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 20rpx;
  box-sizing: border-box;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.actions {
  display: flex;
  gap: 12rpx;
}

.btn {
  background: #4f46e5;
  color: #fff;
  border: 0;
}

.btn.ghost {
  background: #eef2ff;
  color: #4338ca;
}

.workspace {
  display: flex;
  gap: 16rpx;
  height: calc(100vh - 140rpx);
}

.panel {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #4b5563;
  margin-bottom: 10rpx;
}

.editor {
  flex: 1;
  width: 100%;
  background: #0f172a;
  color: #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  line-height: 1.5;
  font-family: Menlo, Monaco, Consolas, monospace;
}

.error {
  margin-top: 8rpx;
  color: #dc2626;
  font-size: 22rpx;
}

.phone-shell {
  width: 100%;
  height: 100%;
  border: 1px solid #d1d5db;
  border-radius: 28rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #f8fafc;
}

.phone-status {
  height: 42rpx;
  padding: 0 20rpx;
  background: #111827;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.phone-navbar {
  height: 72rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  border-bottom: 1px solid #e5e7eb;
}

.phone-content {
  flex: 1;
  overflow: auto;
  padding: 20rpx;
  box-sizing: border-box;
}

.welcome-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.welcome-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.hero-card {
  margin-top: 14rpx;
  border-radius: 20rpx;
  padding: 20rpx;
  color: #fff;
}

.hero-tag {
  display: inline-flex;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.24);
  font-size: 20rpx;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  opacity: 0.95;
}

.section-title {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #374151;
  font-weight: 600;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
}

.action-item {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #fff;
}

.action-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.action-hint {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #6b7280;
}

.feed-item {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #fff;
  margin-bottom: 8rpx;
}

.feed-title {
  font-size: 24rpx;
  color: #111827;
  font-weight: 600;
}

.feed-meta {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #6b7280;
}

.tabbar {
  height: 86rpx;
  background: #fff;
  border-top: 1px solid #e5e7eb;
  display: flex;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9ca3af;
  font-size: 22rpx;
}

.tab-item.active {
  color: #4f46e5;
  font-weight: 700;
}
