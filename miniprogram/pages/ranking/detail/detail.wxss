.ranking-page {
  height: 100vh;
  background: linear-gradient(180deg, #f7f8ff 0%, #eef3ff 100%);
  overflow: hidden;
}

.ranking-shell {
  height: calc(100vh - env(safe-area-inset-bottom));
  padding: 0 38rpx calc(31rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 19rpx;
}

.ranking-hero {
  border-radius: 46rpx;
  padding: 35rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #2240d6 0%, #5569ff 62%, #8459f7 100%);
  box-shadow: 0 18rpx 46rpx rgba(78, 70, 229, 0.28);
}

.ranking-hero-title {
  font-size: 38rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #f3f6ff;
}

.ranking-hero-desc {
  margin-top: 15rpx;
  font-size: 23rpx;
  line-height: 1.42;
  color: #e8eeff;
}

.ranking-metrics {
  display: flex;
  gap: 15rpx;
}

.metric-card {
  flex: 1;
  border-radius: 35rpx;
  background: rgba(255, 255, 255, 0.92);
  padding: 19rpx 23rpx;
  box-sizing: border-box;
}

.metric-value {
  font-size: 35rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2937;
}

.metric-label {
  margin-top: 4rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #6b7280;
}

.ranking-card {
  border-radius: 35rpx;
  background: #ffffffe8;
  padding: 23rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.ranking-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.ranking-card-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #111827;
}

.ranking-card-hint {
  font-size: 23rpx;
  font-weight: 600;
  color: #9ca3af;
}

.ranking-filter-row {
  display: flex;
  gap: 15rpx;
}

.ranking-filter-chip {
  flex: 1;
  min-height: 62rpx;
  border-radius: 27rpx;
  background: #f4f7fd;
  border: 1rpx solid #e4ebf5;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 700;
  color: #4b5563;
}

.ranking-filter-chip-active {
  background: linear-gradient(180deg, #635bff 0%, #4f46e5 100%);
  border-color: transparent;
  color: #ffffff;
}

.ranking-list-card {
  height: 963rpx;
  padding-bottom: 23rpx;
  overflow: hidden;
}

.ranking-list-shell {
  position: relative;
  height: 778rpx;
  overflow: hidden;
}

.ranking-list {
  max-height: 778rpx;
  height: 778rpx;
  box-sizing: border-box;
}

.ranking-row {
  display: flex;
  align-items: center;
  gap: 19rpx;
  height: 123rpx;
  padding: 21rpx 23rpx;
  box-sizing: border-box;
  border-radius: 31rpx;
  background: #f8f9fd;
}

.ranking-row-active {
  background: #eef2ff;
}

.ranking-row + .ranking-row {
  margin-top: 17rpx;
}

.ranking-index {
  width: 54rpx;
  height: 54rpx;
  border-radius: 19rpx;
  background: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 700;
  color: #667085;
  flex: none;
}

.ranking-index-active {
  background: #4f46e5;
  color: #ffffff;
}

.ranking-copy {
  flex: 1;
  min-width: 0;
}

.ranking-row-title {
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #454648;
}
