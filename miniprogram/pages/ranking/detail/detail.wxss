.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F8FF 0%, #EEF3FF 100%);
}

.page-shell {
  position: relative;
  padding: 0 20rpx calc(32rpx + env(safe-area-inset-bottom));
}

.floating-label {
  position: absolute;
  top: 10rpx;
  left: 20rpx;
  z-index: 2;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.8);
  color: #FFFFFF;
  font-size: 19rpx;
  font-weight: 700;
}

.hero-card {
  margin-top: 48rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1F3FD8 0%, #5668FF 62%, #8B5CF6 100%);
  color: #FFFFFF;
  box-shadow: 0 18rpx 40rpx rgba(79, 70, 229, 0.28);
}

.hero-eyebrow {
  font-size: 19rpx;
  font-family: 'IBM Plex Mono', monospace;
  letter-spacing: 1.4rpx;
  color: #DBE5FF;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 700;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.42;
  color: #E9EEFF;
}

.stat-grid {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.stat-card {
  flex: 1;
  padding: 12rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
}

.stat-value {
  font-size: 46rpx;
  font-weight: 700;
  color: #0F172A;
}

.stat-label {
  margin-top: 4rpx;
  font-size: 21rpx;
  font-weight: 600;
  color: #667085;
}

.section-card {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
}

.section-card-soft {
  background: rgba(238, 244, 255, 0.95);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #111827;
}

.section-hint {
  font-size: 21rpx;
  font-weight: 600;
  color: #667085;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.filter-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #EEF1FF;
  color: #667085;
  font-size: 21rpx;
  font-weight: 700;
}

.filter-pill-active {
  background: #5D56EC;
  color: #FFFFFF;
}

.ranking-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ranking-item {
  display: flex;
  gap: 12rpx;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #F8FAFF;
}

.row-index {
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 700;
}

.row-index-violet {
  background: #EDE9FE;
  color: #7C3AED;
}

.row-index-slate {
  background: #E5E7EB;
  color: #64748B;
}

.row-index-amber {
  background: #FEF3C7;
  color: #D97706;
}

.row-copy {
  flex: 1;
}

.row-title {
  font-size: 25rpx;
  font-weight: 700;
  color: #111827;
}

.row-meta,
.section-body {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.45;
  font-weight: 600;
  color: #667085;
}

.footer-row {
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.footer-btn {
  flex: 1;
  height: 46rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 700;
}

.footer-btn-secondary {
  border: 1rpx solid #D4DCE8;
  background: rgba(255, 255, 255, 0.92);
  color: #344054;
}

.footer-btn-primary {
  background: linear-gradient(180deg, #6056FF 0%, #3C4DDF 100%);
  color: #FFFFFF;
}
