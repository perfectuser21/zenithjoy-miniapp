<view class="ranking-page">
  <view class="ranking-shell" style="padding-top: {{statusBarHeight + 3}}px;">
    <view class="ranking-hero">
      <view class="ranking-hero-title">{{heroTitle}}</view>
      <view class="ranking-hero-desc">{{heroDescription}}</view>
    </view>

    <view class="ranking-metrics">
      <view class="metric-card" wx:for="{{metrics}}" wx:key="label">
        <view class="metric-value">{{item.value}}</view>
        <view class="metric-label">{{item.label}}</view>
      </view>
    </view>

    <view class="ranking-card">
      <view class="ranking-card-head">
        <view class="ranking-card-title">{{filterTitle}}</view>
        <view class="ranking-card-hint">{{filterHint}}</view>
      </view>
      <view class="ranking-filter-row">
        <view
          class="ranking-filter-chip {{item.active ? 'ranking-filter-chip-active' : ''}}"
          wx:for="{{filters}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="switchFilter"
        >{{item.label}}</view>
      </view>
    </view>

    <view class="ranking-card ranking-list-card">
      <view class="ranking-card-head">
        <view class="ranking-card-title">{{topListTitle}}</view>
        <view class="ranking-card-hint">{{topListHint}}</view>
      </view>
      <view class="ranking-list-shell">
        <scroll-view class="ranking-list" scroll-y="true" show-scrollbar="true">
          <view class="ranking-row {{item.index === '01' ? 'ranking-row-active' : ''}}" wx:for="{{rankingItems}}" wx:key="index">
            <view class="ranking-index {{item.index === '01' ? 'ranking-index-active' : ''}}">{{item.index}}</view>
            <view class="ranking-copy">
              <view class="ranking-row-title">{{item.title}}</view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
</view>
