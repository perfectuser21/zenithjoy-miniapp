/* pages/article-list/article-list.wxss */
.container {
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 84% 10%, rgba(122, 109, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.header {
  display: flex;
  align-items: center;
  padding: 0 0 24rpx;
  background-color: transparent;
  margin-bottom: 0;
  box-shadow: none;
}

.logo {
  width: 60rpx;
  height: 60rpx;
  margin-right: 16rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #111827;
}

/* 文章列表样式 */
.article-list {
  padding: 0;
}

.list-header {
  padding: 0 0 18rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
  border-bottom: none;
  margin-bottom: 20rpx;
}

.article-item {
  display: flex;
  padding: 24rpx;
  border-bottom: none;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
  margin-bottom: 18rpx;
}

.cover {
  width: 180rpx;
  height: 136rpx;
  border-radius: 20rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.info {
  flex: 1;
  padding-left: 18rpx;
  display: flex;
  flex-direction: column;
}

.info .title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.info .desc {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 15rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #8f95af;
  margin-top: auto;
}

.date {
  color: #8f95af;
}

.tag {
  background-color: #eef0ff;
  color: #5a4cff;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.empty-list {
  padding: 120rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8f95af;
}

.empty-list image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

/* 加载中样式 */
.loading {
  padding: 48rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8f95af;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}
