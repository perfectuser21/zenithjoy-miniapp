/* pages/article-list/index.wxss */
.container {
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 84% 10%, rgba(122, 109, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.article-list {
  padding-bottom: 0;
}

.article-item {
  background-color: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.article-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 14rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.article-summary {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 18rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
}

.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.article-date {
  font-size: 24rpx;
  color: #8f95af;
}

.loading {
  padding: 36rpx 0;
  text-align: center;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.empty-tip {
  padding: 120rpx 0;
  text-align: center;
  color: #8f95af;
  font-size: 30rpx;
}

.no-more {
  text-align: center;
  color: #8f95af;
  font-size: 24rpx;
  padding: 36rpx 0;
}
