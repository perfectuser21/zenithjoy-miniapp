/* pages/article-detail/index.wxss */
.container {
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 84% 10%, rgba(122, 109, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.article-header {
  margin-bottom: 28rpx;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.article-title {
  font-size: 42rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  align-items: center;
}

.article-date {
  font-size: 26rpx;
  color: #8f95af;
}

.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #1f2937;
  margin-bottom: 28rpx;
  text-align: justify;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
  white-space: pre-wrap;
}

.action-buttons {
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.copy-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: white;
  font-size: 28rpx;
  border-radius: 24rpx;
}

.loading {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 28rpx;
}

.empty-tip {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f95af;
  font-size: 30rpx;
}
