/* pages/article-detail/article-detail.wxss */

.container {
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background:
    radial-gradient(circle at 84% 10%, rgba(122, 109, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
  min-height: 100vh;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #6b7280;
}

/* 错误提示 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 50rpx;
}

.error-text {
  margin-top: 30rpx;
  font-size: 32rpx;
  color: #6b7280;
  text-align: center;
}

.back-btn {
  margin-top: 50rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: white;
  font-size: 28rpx;
  width: 280rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
}

/* 文章容器 */
.article-container {
  background-color: rgba(255, 255, 255, 0.94);
  border-radius: 30rpx;
  padding: 32rpx 24rpx;
  margin: 0;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

/* 文章头部 */
.article-header {
  margin-bottom: 24rpx;
}

.article-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #1f2937;
  line-height: 1.4;
  display: block;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #8f95af;
}

.article-author {
  margin-right: 20rpx;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 22rpx;
  color: #5a4cff;
  background-color: #eef0ff;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

/* 文章封面 */
.article-cover {
  width: 100%;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
}

/* 文章内容 */
.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #1f2937;
  margin-bottom: 28rpx;
}

/* 文章底部 */
.article-footer {
  border-top: 1rpx solid #eef1f8;
  padding-top: 24rpx;
  display: flex;
  justify-content: center;
}

.share-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: white;
  font-size: 28rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-text {
  color: white;
}
