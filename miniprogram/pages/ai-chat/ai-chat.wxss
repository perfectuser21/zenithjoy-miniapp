.page {
  height: 100vh;
  background:
    radial-gradient(circle at 15% 8%, rgba(122, 109, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
  padding: 0 32rpx calc(164rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.eyebrow {
  font-size: 18rpx;
  color: #6c63ff;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.title {
  font-size: 58rpx;
  line-height: 1.05;
  font-weight: 700;
  color: #111827;
}

.status-box {
  min-width: 178rpx;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.76);
  border-radius: 22rpx;
  text-align: right;
  flex-shrink: 0;
}

.status-title {
  font-size: 20rpx;
  color: #6c63ff;
  font-weight: 600;
}

.status-meta {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #8f95af;
}

.assistant-panel {
  padding: 28rpx 24rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 30rpx 30rpx 0 0;
  border-bottom: 1rpx solid rgba(108, 99, 255, 0.08);
}

.assistant-name {
  font-size: 24rpx;
  color: #5b647d;
  margin-bottom: 18rpx;
}

.starter-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.starter-badge,
.message-badge {
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7b71ff 0%, #9e82ff 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.starter-bubble,
.message-bubble {
  flex: 1;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f5f4ff;
  color: #374151;
  font-size: 24rpx;
  line-height: 1.6;
}

.starter-action {
  width: 100%;
  margin: 20rpx auto 0;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
}

.conversation {
  flex: 1;
  min-height: 0;
  padding: 20rpx 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 0 0 30rpx 30rpx;
}

.message {
  display: flex;
  margin-bottom: 18rpx;
}

.assistant {
  align-items: flex-start;
}

.user {
  justify-content: flex-end;
}

.user-bubble {
  flex: initial;
  max-width: 86%;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: #ffffff;
}

.message-error {
  background: #fff1f2;
  color: #c2410c;
}

.message-text {
  color: inherit;
  line-height: 1.7;
}

.loading-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-wrap: wrap;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #8f95af;
  animation: dot-flash 1s infinite alternate;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-flash {
  from { opacity: 0.3; }
  to { opacity: 1; }
}

.prompt-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 0;
}

.prompt-chip {
  width: calc((100% - 24rpx) / 3);
  min-height: 72rpx;
  padding: 0 12rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 20rpx;
  background: rgba(235, 238, 255, 0.9);
  color: #6c63ff;
  font-size: 20rpx;
  box-sizing: border-box;
}

.input-bar {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.message-input {
  flex: 1;
  height: 84rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(108, 99, 255, 0.1);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #374151;
}

.send-button {
  width: 124rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: #ffffff;
  font-size: 24rpx;
}

.send-button-disabled {
  background: #c7ccdf;
  color: #ffffff;
}

.conversation-anchor {
  height: 1rpx;
}
