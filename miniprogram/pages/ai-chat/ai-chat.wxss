.chat-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(247, 206, 151, 0.24), transparent 28%),
    linear-gradient(180deg, #f4eee5 0%, #f7f4ef 34%, #fbfaf7 100%);
  padding-bottom: calc(210rpx + env(safe-area-inset-bottom));
}

.system-messages {
  position: fixed;
  top: 18rpx;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.system-message {
  margin: 6rpx 0;
  padding: 10rpx 26rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  max-width: 90%;
  text-align: center;
  animation: fadeIn 0.3s ease-in, fadeOut 0.3s ease-out 4.7s forwards;
}

.system-message-info {
  background-color: rgba(29, 61, 54, 0.86);
  color: white;
}

.system-message-success {
  background-color: rgba(52, 199, 89, 0.8);
  color: white;
}

.system-message-warning {
  background-color: rgba(255, 149, 0, 0.8);
  color: white;
}

.system-message-error {
  background-color: rgba(255, 59, 48, 0.8);
  color: white;
}

.workflow-panel {
  margin: 34rpx 24rpx 18rpx;
  padding: 28rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(92, 71, 56, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(71, 50, 34, 0.08);
}

.workflow-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.workflow-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 64, 57, 0.1);
  color: #21423c;
  font-size: 22rpx;
  font-weight: 600;
}

.workflow-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #241813;
}

.workflow-objective {
  font-size: 26rpx;
  line-height: 1.65;
  color: #665448;
  margin-bottom: 18rpx;
}

.workflow-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.metric-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(243, 239, 232, 0.95);
  color: #7b685b;
  font-size: 22rpx;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

.messages-container {
  flex: 1;
  overflow-y: auto;
  padding: 0 24rpx 32rpx;
}

.message-item {
  max-width: 86%;
  margin-bottom: 28rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  animation: fadeInLeft 0.3s ease-out;
}

@keyframes fadeInLeft {
  from { 
    opacity: 0; 
    transform: translateX(-20rpx);
  }
  to { 
    opacity: 1; 
    transform: translateX(0);
  }
}

.user-message {
  align-self: flex-end;
  margin-left: auto;
  animation: fadeInRight 0.3s ease-out;
}

@keyframes fadeInRight {
  from { 
    opacity: 0; 
    transform: translateX(20rpx);
  }
  to { 
    opacity: 1; 
    transform: translateX(0);
  }
}

.assistant-message {
  align-self: flex-start;
  margin-right: auto;
}

.message-label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #8d7867;
  margin-bottom: 10rpx;
}

.message-content {
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  word-break: break-word;
  position: relative;
}

.user-message .message-content {
  background: linear-gradient(180deg, #1f4138 0%, #18312b 100%);
  color: #f8efe6;
  border-top-right-radius: 8rpx;
}

.assistant-message .message-content {
  background-color: rgba(255, 255, 255, 0.86);
  color: #2a211d;
  border-top-left-radius: 8rpx;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.07);
}

.error-message .message-content {
  background-color: #fff0ed;
  color: #d32f2f;
}

.message-time {
  font-size: 20rpx;
  color: #948275;
  margin-top: 10rpx;
  align-self: flex-end;
}

.loading-dots {
  display: inline-flex;
  margin-right: 10rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #999;
  border-radius: 50%;
  margin: 0 3rpx;
  display: inline-block;
  animation: dot-flashing 1s infinite alternate;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-flashing {
  0% { opacity: 0.3; }
  100% { opacity: 1; }
}

.prompt-panel {
  margin: 0 24rpx 18rpx;
}

.prompt-title {
  font-size: 24rpx;
  color: #7f6e62;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.prompt-scroll {
  white-space: nowrap;
}

.prompt-list {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 20rpx;
}

.prompt-chip {
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(90, 70, 54, 0.08);
  color: #4d3d33;
  font-size: 24rpx;
  line-height: 1.45;
}

.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: rgba(250, 247, 243, 0.96);
  border-top: 1rpx solid rgba(92, 71, 56, 0.08);
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.04);
  z-index: 10;
}

.message-input {
  flex: 1;
  height: 84rpx;
  background-color: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #332822;
  border: 1rpx solid rgba(90, 70, 54, 0.08);
}

.send-button {
  width: 132rpx;
  height: 84rpx;
  line-height: 84rpx;
  margin-left: 16rpx;
  background-color: #1d1a17;
  color: #f7efe6;
  border-radius: 28rpx;
  font-size: 28rpx;
  padding: 0;
}

.send-button-disabled {
  background-color: rgba(29, 26, 23, 0.45);
}

.message-images {
  margin-top: 16rpx;
  width: 100%;
}

.image-gallery {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.content-image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
}

.single-image .content-image {
  width: 100%;
  max-height: 400rpx;
}

.assistant-message + .assistant-message {
  margin-top: 12rpx;
}

.assistant-message .message-content strong,
.assistant-message .message-content .title-text {
  font-weight: bold;
  color: #21423c;
}

@keyframes pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(7, 193, 96, 0.1);
  }
  70% {
    box-shadow: 0 0 0 6rpx rgba(7, 193, 96, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(7, 193, 96, 0);
  }
}
