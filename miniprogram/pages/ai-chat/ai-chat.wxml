<view class="page">
  <view class="top" style="padding-top: {{statusBarHeight + 12}}px;">
    <view>
      <view class="eyebrow">AI ASSISTANT</view>
      <view class="title">AI 助理</view>
    </view>
    <view class="status-box">
      <view class="status-title">在线服务中</view>
      <view class="status-meta">平均回复 2s</view>
    </view>
  </view>

  <view class="assistant-panel">
    <view class="assistant-name">AI 对话区</view>
    <view class="starter-row">
      <view class="starter-badge">AI</view>
      <view class="starter-bubble">{{welcomeText}}</view>
    </view>
    <view class="starter-action" bindtap="usePromptChip" data-prompt="{{primaryPrompt}}">{{primaryPrompt}}</view>
  </view>

  <scroll-view scroll-y class="conversation" scroll-with-animation scroll-into-view="{{scrollAnchor}}">
    <block wx:for="{{messages}}" wx:key="index">
      <view wx:if="{{index > 0 && item.role === 'assistant'}}" class="message assistant">
        <view class="message-badge">AI</view>
        <view class="message-bubble {{item.isError ? 'message-error' : ''}}">
          <block wx:if="{{item.isLoading}}">
            <view class="loading-row">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
              <text>{{item.content}}</text>
            </view>
          </block>
          <block wx:else>
            <text class="message-text" selectable="true" user-select="true">{{item.content}}</text>
          </block>
        </view>
      </view>

      <view wx:if="{{item.role === 'user'}}" class="message user">
        <view class="message-bubble user-bubble">{{item.content}}</view>
      </view>
    </block>
    <view id="msg-bottom" class="conversation-anchor"></view>
  </scroll-view>

  <view class="prompt-bar">
    <view class="prompt-chip" wx:for="{{quickActions}}" wx:key="*this" bindtap="usePromptChip" data-prompt="{{item}}">
      {{item}}
    </view>
  </view>

  <view class="input-bar">
    <input
      class="message-input"
      value="{{inputValue}}"
      bindinput="handleInputChange"
      placeholder="输入你的问题..."
      confirm-type="send"
      bindconfirm="sendMessage"
      disabled="{{sending}}"
    />
    <button
      class="send-button {{sending ? 'send-button-disabled' : ''}}"
      bindtap="sendMessage"
      disabled="{{sending || !inputValue}}"
    >发送</button>
  </view>
</view>
