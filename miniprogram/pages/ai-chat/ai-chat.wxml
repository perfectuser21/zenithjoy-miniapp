<view class="chat-container">
  <view class="system-messages">
    <block wx:for="{{systemMessages}}" wx:key="index">
      <view class="system-message system-message-{{item.type}}">
        {{item.content}}
      </view>
    </block>
  </view>

  <view class="workflow-panel">
    <view class="workflow-top">
      <view class="workflow-badge">{{workflowMeta.badge}}</view>
      <view class="workflow-title">{{title}}</view>
    </view>
    <view class="workflow-objective">{{workflowMeta.objective}}</view>
    <view class="workflow-metrics">
      <view class="metric-chip" wx:for="{{workflowMeta.metrics}}" wx:key="*this">{{item}}</view>
    </view>
  </view>

  <view class="messages-container" id="message-container">
    <block wx:for="{{messages}}" wx:key="index">
      <view wx:if="{{item.role === 'user'}}" class="message-item user-message">
        <view class="message-label">{{item.label || '你的输入'}}</view>
        <view class="message-content">{{item.content}}</view>
        <view class="message-time">{{item.time}}</view>
      </view>

      <view wx:else class="message-item assistant-message {{item.isError ? 'error-message' : ''}}">
        <view class="message-label">{{item.label || '工作流输出'}}</view>
        <view class="message-content">
          <block wx:if="{{item.isLoading}}">
            <view class="loading-dots">
              <view class="dot"></view>
              <view class="dot"></view>
              <view class="dot"></view>
            </view>
            {{item.content}}
          </block>
          <block wx:else>
            <text selectable="true" user-select="true" class="message-text">{{item.content}}</text>

            <view wx:if="{{item.images && item.images.length > 0}}" class="message-images {{item.images.length === 1 ? 'single-image' : 'image-gallery'}}">
              <block wx:for="{{item.images}}" wx:for-item="img" wx:key="id">
                <image 
                  src="{{img.url || img.mpUrl}}"
                  mode="aspectFit"
                  lazy-load="true"
                  class="content-image"
                  bindtap="previewImage"
                  data-index="{{index}}"
                  data-item="{{item}}"
                ></image>
              </block>
            </view>
          </block>
        </view>
        <view class="message-time">{{item.time}}</view>
      </view>
    </block>
  </view>

  <view class="prompt-panel">
    <view class="prompt-title">继续追问</view>
    <scroll-view scroll-x="true" class="prompt-scroll" show-scrollbar="false">
      <view class="prompt-list">
        <view
          class="prompt-chip"
          wx:for="{{workflowMeta.prompts}}"
          wx:key="*this"
          bindtap="usePromptChip"
          data-prompt="{{item}}"
        >{{item}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="input-container">
    <input 
      class="message-input" 
      value="{{inputValue}}" 
      bindinput="handleInputChange" 
      placeholder="继续补充你的目标、风格或约束..."
      confirm-type="send"
      bindconfirm="sendMessage"
      disabled="{{sending}}"
    />
    <button 
      class="send-button {{sending ? 'send-button-disabled' : ''}}" 
      bindtap="sendMessage" 
      disabled="{{sending || !inputValue}}"
    >发送</button>
  </view>
</view> 
