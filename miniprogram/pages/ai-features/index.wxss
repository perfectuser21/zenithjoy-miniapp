.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% 8%, rgba(114, 107, 255, 0.14), transparent 28%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
  padding: 0 28rpx calc(44rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-bottom: 16rpx;
}

.eyebrow {
  font-size: 19rpx;
  color: #6d63ff;
  margin-bottom: 6rpx;
}

.title {
  font-size: 54rpx;
  line-height: 1.06;
  font-weight: 700;
  color: #111827;
}

.points-chip {
  padding: 12rpx 18rpx;
  background: #eef0ff;
  border-radius: 20rpx;
  color: #5a52d6;
  font-size: 19rpx;
  font-weight: 600;
}

.hero-banner {
  position: relative;
  margin-top: 16rpx;
  height: 228rpx;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(104, 113, 176, 0.16);
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(17, 24, 39, 0.4) 0%, rgba(17, 24, 39, 0.12) 100%);
}

.hero-copy {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  color: #ffffff;
}

.hero-copy-kicker {
  font-size: 17rpx;
  opacity: 0.9;
  margin-bottom: 6rpx;
  font-weight: 700;
}

.hero-copy-title {
  font-size: 36rpx;
  line-height: 1.14;
  font-weight: 700;
}

.hero-copy-desc {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.35;
  opacity: 0.92;
}

.section {
  margin-top: 16rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 28rpx;
  border: 1rpx solid rgba(108, 99, 255, 0.08);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.section-flow {
  gap: 0;
}

.section-title {
  font-size: 27rpx;
  color: #1d2340;
  font-weight: 700;
}

.section-meta {
  font-size: 19rpx;
  color: #7a7e9a;
  font-weight: 600;
}

.step-shell {
  position: relative;
  margin-top: 14rpx;
  padding-left: 6rpx;
}

.step-rail {
  position: absolute;
  top: 18rpx;
  bottom: 18rpx;
  left: 30rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(114, 103, 255, 0.22) 0%, rgba(114, 103, 255, 0.06) 100%);
  pointer-events: none;
}

.step-list {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.step-card {
  flex: 1;
  min-height: 92rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #f8f7ff 0%, #eef2ff 100%);
  border: 1rpx solid rgba(114, 103, 255, 0.08);
  box-shadow: 0 10rpx 24rpx rgba(121, 131, 180, 0.08);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.step-index {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7c71ff 0%, #9c88ff 100%);
  color: #ffffff;
  text-align: center;
  font-size: 18rpx;
  font-weight: 700;
}

.step-title {
  font-size: 24rpx;
  color: #2d3553;
  font-weight: 700;
}

.step-desc {
  margin-top: 6rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #6d7591;
}

.flow-note {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(108, 99, 255, 0.08);
  color: #5f6490;
  font-size: 19rpx;
  line-height: 1.5;
}

.primary-cta,
.secondary-cta {
  margin-top: 16rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 21rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  box-shadow: 0 14rpx 28rpx rgba(108, 99, 255, 0.2);
}

.primary-cta {
  font-size: 24rpx;
}

.pill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.pill-item {
  width: calc((100% - 16rpx) / 2);
  min-height: 44rpx;
  padding: 0 14rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #f1eeff;
  color: #6c63ff;
  font-size: 18rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.pill-item-active {
  background: #928bed;
  color: #ffffff;
}

.pill-item-blue {
  background: #eef1ff;
  color: #4f62c6;
}

.secondary-cta {
  background: linear-gradient(180deg, #ebe5ff 0%, #ddd5ff 100%);
  color: #5a4cff;
  box-shadow: none;
  border: 1rpx solid rgba(174, 157, 255, 0.7);
}

.secondary-cta-blue {
  background: linear-gradient(180deg, #e6eeff 0%, #d8e3ff 100%);
  color: #3856a8;
  border: 1rpx solid rgba(175, 194, 255, 0.9);
}

.safe-bottom {
  height: 0;
}
