.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% 8%, rgba(114, 107, 255, 0.14), transparent 28%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
  padding: 0 32rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-head,
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero {
  padding-bottom: 24rpx;
}

.eyebrow {
  font-size: 24rpx;
  color: #6d63ff;
  margin-bottom: 6rpx;
}

.title {
  font-size: 64rpx;
  line-height: 1.04;
  font-weight: 700;
  color: #111827;
}

.points-chip {
  padding: 16rpx 20rpx;
  background: #eef0ff;
  border-radius: 24rpx;
  color: #5a52d6;
  font-size: 26rpx;
  font-weight: 600;
}

.hero-banner {
  position: relative;
  margin-top: 22rpx;
  height: 296rpx;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(104, 113, 176, 0.16);
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(17, 24, 39, 0.4) 0%, rgba(17, 24, 39, 0.12) 100%);
}

.hero-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 24rpx;
  color: #ffffff;
}

.hero-copy-kicker {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
  font-weight: 700;
}

.hero-copy-title {
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 700;
}

.hero-copy-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.35;
  opacity: 0.92;
}

.section {
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 32rpx;
  border: 1rpx solid rgba(108, 99, 255, 0.08);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.section-title {
  font-size: 34rpx;
  color: #1d2340;
  font-weight: 700;
}

.section-meta {
  font-size: 26rpx;
  color: #7a7e9a;
  font-weight: 600;
}

.step-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 20rpx;
}

.step-chip {
  width: 74rpx;
  min-height: 84rpx;
  padding: 16rpx 12rpx;
  border-radius: 20rpx;
  background: #f2f3ff;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.step-index {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  margin: 0 auto 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #7c71ff 0%, #9c88ff 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.step-title {
  font-size: 26rpx;
  color: #2d3553;
  font-weight: 700;
}

.step-arrow {
  color: #a1a8c4;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-cta,
.secondary-cta {
  margin-top: 20rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  box-shadow: 0 14rpx 28rpx rgba(108, 99, 255, 0.2);
}

.pill-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.pill-item {
  width: calc((100% - 16rpx) / 2);
  min-height: 48rpx;
  padding: 0 16rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 18rpx;
  background: #f1eeff;
  color: #6c63ff;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.pill-item-blue {
  background: #eef1ff;
  color: #4f62c6;
}

.secondary-cta {
  background: linear-gradient(180deg, #ebe5ff 0%, #ddd5ff 100%);
  color: #5a4cff;
  box-shadow: none;
  border: 1rpx solid rgba(174, 157, 255, 0.7);
}

.secondary-cta-blue {
  background: linear-gradient(180deg, #e6eeff 0%, #d8e3ff 100%);
  color: #3856a8;
  border: 1rpx solid rgba(175, 194, 255, 0.9);
}

.safe-bottom {
  height: 0;
}
