@import "/styles/pencil-theme.wxss";

.p-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% 8%, rgba(114, 107, 255, 0.14), transparent 28%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.p-shell {
  padding: 0 28rpx calc(144rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.p-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(108, 99, 255, 0.08);
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.p-hero-card {
  background: linear-gradient(180deg, rgba(108, 99, 255, 0.16) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.p-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.p-kicker,
.p-action-label {
  font-size: 19rpx;
  color: #6d63ff;
  letter-spacing: 1.6rpx;
}

.p-title {
  margin-top: 8rpx;
  font-size: 54rpx;
  line-height: 1.06;
  font-weight: 700;
  color: #111827;
}

.p-points-chip {
  padding: 12rpx 18rpx;
  background: #eef0ff;
  border-radius: 20rpx;
  color: #5a52d6;
  font-size: 19rpx;
  font-weight: 600;
}

.p-subtitle,
.p-action-desc {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #707998;
}

.p-action-title {
  margin-top: 10rpx;
  font-size: 32rpx;
  line-height: 1.2;
  color: #1d2340;
  font-weight: 700;
}
