<view class="p-page">
  <view class="p-shell" style="padding-top: {{statusBarHeight + 8}}px;">
    <view class="p-head">
      <view class="p-head-left">
        <view class="p-brand">{{eyebrow}}</view>
        <view class="p-page-title">{{pageTitle}}</view>
      </view>
    </view>

    <view class="p-banner-card">
      <image class="p-banner-image" src="{{heroCard.image}}" mode="aspectFill"></image>
      <view class="p-banner-overlay"></view>
      <view class="p-banner-content">
        <view class="p-kicker">{{heroCard.kicker}}</view>
        <view class="p-title">{{heroCard.title}}</view>
        <view class="p-subtitle">{{heroCard.description}}</view>
      </view>
    </view>

    <view
      wx:for="{{sections}}"
      wx:key="title"
      class="p-card p-process-card p-process-card-{{item.tone}}"
      bindtap="openSection"
      data-target="{{item.action}}"
    >
      <view class="p-section-head">
        <view class="p-section-title">{{item.title}}</view>
        <view class="p-section-meta">{{item.meta}}</view>
      </view>
      <view class="p-process-shell p-process-shell-{{item.tone}}">
        <view class="p-process-track p-process-track-{{item.tone}}">
          <view class="p-process-steps">
            <view
              wx:for="{{item.steps}}"
              wx:key="*this"
              class="p-process-step"
            >{{item}}</view>
          </view>
        </view>
        <view class="p-process-outcome">{{item.outcome}}</view>
      </view>
      <view class="p-process-cta p-process-cta-{{item.tone}}">{{item.cta}}</view>
    </view>
  </view>
</view>
