<view class="page">
  <view class="hero" style="padding-top: {{statusBarHeight + 12}}px;">
    <view class="hero-head">
      <view>
        <view class="eyebrow">CREATE STUDIO</view>
        <view class="title">今天创作什么</view>
      </view>
      <view class="points-chip">可用积分 {{points}}</view>
    </view>

    <view class="hero-banner">
      <image class="hero-image" src="/images/studio-banner.png" mode="aspectFill"></image>
      <view class="hero-mask"></view>
      <view class="hero-copy">
        <view class="hero-copy-kicker">CREATOR FLOW</view>
        <view class="hero-copy-title">让内容生产不再成为难题</view>
        <view class="hero-copy-desc">沿着热点榜单与创作流程执行，稳定产出可发布内容。</view>
      </view>
    </view>
  </view>

  <view class="section section-flow">
    <view class="section-head">
      <view class="section-title">自媒体创作区域</view>
      <view class="section-meta">6 步完成一轮创作</view>
    </view>
    <view class="step-shell">
      <view class="step-rail"></view>
      <view class="step-list">
        <block wx:for="{{creationSteps}}" wx:key="no">
          <view class="step-item">
            <view class="step-index">{{item.no}}</view>
            <view class="step-card">
              <view class="step-title">{{item.title}}</view>
              <view class="step-desc">{{item.desc}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>
    <view class="flow-note">从输入创作条件到生成成稿，这里展示的是完整主流程，不再和下方功能入口重复。</view>
    <view class="primary-cta" bindtap="openFeature" data-id="writer">开始文案创作</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">标题创作</view>
      <view class="section-meta">基于当前选题</view>
    </view>
    <view class="pill-grid">
      <view class="pill-item {{index === 0 ? 'pill-item-active' : ''}}" wx:for="{{titleActions}}" wx:key="label" bindtap="openFeature" data-id="{{item.bot}}">
        {{item.label}}
      </view>
    </view>
    <view class="secondary-cta" bindtap="openFeature" data-id="content">生成标题 →</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">朋友圈文案</view>
      <view class="section-meta">根据需求生成</view>
    </view>
    <view class="pill-grid">
      <view class="pill-item pill-item-blue" wx:for="{{momentActions}}" wx:key="label" bindtap="openFeature" data-id="{{item.bot}}">
        {{item.label}}
      </view>
    </view>
    <view class="secondary-cta secondary-cta-blue" bindtap="openFeature" data-id="expert">生成朋友圈文案 →</view>
  </view>

  <view class="safe-bottom"></view>
</view>
