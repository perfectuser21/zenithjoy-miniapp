/* pages/ai-features/ai-features.wxss */
.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background:
    radial-gradient(circle at 14% 18%, rgba(91, 227, 255, 0.18), transparent 32%),
    radial-gradient(circle at 86% 8%, rgba(123, 97, 255, 0.2), transparent 30%),
    linear-gradient(180deg, #0b1020 0%, #0f172c 36%, #111a30 100%);
  min-height: 100vh;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #f4f7ff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #9db5d8;
}

.feature-list {
  background-color: rgba(18, 26, 48, 0.9);
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 18rpx 42rpx rgba(6, 12, 28, 0.24);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #4ce0ff 0%, #7a6dff 100%);
}

.ai-chat-icon {
  background-color: rgba(79, 227, 255, 0.18);
  position: relative;
}

.ai-chat-icon:after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40rpx;
  height: 40rpx;
  background-color: #0b0f1d;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #eef4ff;
  margin-bottom: 6rpx;
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: #9eb6de;
  display: block;
}

.feature-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #7fe0ff;
  border-right: 2rpx solid #7fe0ff;
  transform: rotate(45deg);
}

.tips {
  background-color: rgba(18, 26, 48, 0.9);
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 18rpx 42rpx rgba(6, 12, 28, 0.24);
  border: 1rpx solid rgba(120, 186, 255, 0.18);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #eef4ff;
  margin-bottom: 16rpx;
  display: block;
}

.tips-item {
  display: flex;
  margin-bottom: 10rpx;
  align-items: flex-start;
}

.tips-dot {
  color: #7fe0ff;
  margin-right: 10rpx;
  font-weight: bold;
}

.tips-text {
  font-size: 24rpx;
  color: #9db5d8;
  line-height: 1.5;
}
