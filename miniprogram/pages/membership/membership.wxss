/* 会员中心页面样式 */
.membership-container {
  padding: 32rpx 32rpx calc(64rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  min-height: 100vh;
  background:
    radial-gradient(circle at 88% 10%, rgba(255, 184, 0, 0.16), transparent 26%),
    linear-gradient(180deg, #fffaf0 0%, #fff7e8 42%, #f7f8ff 100%);
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background-color: rgba(255, 255, 255, 0.92);
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(120, 96, 40, 0.08);
}

.avatar-container {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.avatar {
  width: 100%;
  height: 100%;
}

.get-info-text {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 4rpx 0;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  color: #1f2937;
}

.member-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background-color: #f0f0f0;
  color: #666;
}

.member-tag.standard {
  background-color: #d4e7ff;
  color: #1987fb;
}

.member-tag.vip {
  background-color: #ffd700;
  color: #865c00;
}

/* 会员卡片 */
.member-card {
  position: relative;
  margin-bottom: 24rpx;
  padding: 32rpx 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
  box-shadow: 0 16rpx 36rpx rgba(51, 41, 16, 0.12);
  overflow: hidden;
}

.member-card::before {
  content: "";
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
}

.standard-card {
  background: linear-gradient(135deg, #44a2ff, #0056b3);
  color: white;
}

.premium-card {
  background: linear-gradient(135deg, #ffb800, #ff7a00);
  color: white;
}

.member-card-header {
  margin-bottom: 28rpx;
}

.member-title {
  font-size: 42rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.member-id {
  font-size: 28rpx;
  opacity: 0.8;
}

.member-card-body {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx 20rpx;
}

.member-info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: bold;
}

.member-card-footer {
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
  padding-top: 30rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-phone {
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  color: inherit;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 使用记录 */
.usage-records {
  background-color: rgba(255, 255, 255, 0.94);
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(120, 96, 40, 0.06);
}

.record-list {
  margin-top: 18rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time {
  color: #666;
  font-size: 28rpx;
}

.record-count {
  font-weight: bold;
  color: #333;
  font-size: 28rpx;
}

.no-records {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 会员权益 */
.member-benefits {
  background-color: rgba(255, 255, 255, 0.94);
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(120, 96, 40, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 22rpx;
  display: flex;
  align-items: center;
  color: #1f2937;
}

.section-title::before {
  content: '';
  display: block;
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #ffb800 0%, #ff7a00 100%);
  margin-right: 16rpx;
  border-radius: 4rpx;
}

.benefits-list {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 18rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #4b5563;
}

.benefit-item icon {
  margin-right: 16rpx;
}

/* 会员套餐 */
.membership-plans {
  background-color: rgba(255, 255, 255, 0.94);
  padding: 28rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 12rpx 32rpx rgba(120, 96, 40, 0.06);
}

.plans-list {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 20rpx;
}

.plan-item {
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #eaeaea;
  background-color: #fff;
  transition: all 0.3s;
}

.current-plan {
  border-color: #07c160;
  background-color: #f0fff6;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.plan-name {
  font-size: 30rpx;
  font-weight: bold;
}

.plan-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background-color: #07c160;
  color: white;
}

.plan-price {
  margin-bottom: 18rpx;
  display: flex;
  align-items: baseline;
}

.price-unit {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 4rpx;
}

.price-value {
  font-size: 52rpx;
  font-weight: bold;
}

.price-original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.plan-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 18rpx;
}

.plan-features {
  margin-bottom: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: #666;
}

.feature-item icon {
  margin-right: 16rpx;
}

.plan-action {
  display: flex;
  justify-content: center;
}

.btn-purchase {
  font-size: 28rpx;
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #ffb800 0%, #ff7a00 100%);
  color: white;
  border-radius: 24rpx;
}

.btn-disabled {
  background-color: #ccc;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  z-index: 1000;
}

.modal-title {
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  border-bottom: 1rpx solid #eaeaea;
}

.modal-content {
  padding: 30rpx;
}

.modal-input-area {
  margin-bottom: 20rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #eaeaea;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.modal-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eaeaea;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
}

.cancel {
  color: #666;
  border-right: 1rpx solid #eaeaea;
}

.confirm {
  color: #07c160;
}

/* 加载状态 */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.7);
  z-index: 9999;
}

.loading {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
} 
