@import "/styles/pencil-theme.wxss";

.p-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 15% 8%, rgba(122, 109, 255, 0.12), transparent 28%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
}

.p-shell {
  padding: 0 32rpx calc(132rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.p-card {
  margin-top: 16rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.p-hero-card {
  background: linear-gradient(180deg, rgba(108, 99, 255, 0.14) 0%, rgba(255, 255, 255, 0.96) 100%);
}

.p-kicker,
.p-action-label {
  font-size: 19rpx;
  color: #6d63ff;
  letter-spacing: 1.4rpx;
}

.p-title {
  margin-top: 8rpx;
  font-size: 58rpx;
  line-height: 1.04;
  font-weight: 700;
  color: #111827;
}

.p-subtitle,
.p-action-desc {
  margin-top: 16rpx;
  font-size: 23rpx;
  line-height: 1.4;
  color: #707998;
}

.p-action-title,
.p-mini-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.2;
  color: #1d2340;
  font-weight: 700;
}

.p-grid {
  display: flex;
  gap: 16rpx;
}

.p-mini-card {
  width: calc((100% - 16rpx) / 2);
  box-sizing: border-box;
}
