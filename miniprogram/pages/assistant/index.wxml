<view class="p-page">
  <view class="p-shell" style="padding-top: {{statusBarHeight + 16}}px;">
    <view class="assistant-head">
      <view class="assistant-head-left">
        <view class="assistant-kicker">AI CHAT HOME</view>
        <view class="assistant-title">{{pageTitle}}</view>
      </view>
      <view class="assistant-state">
        <view class="assistant-state-label">{{onlineState}}</view>
        <view class="assistant-state-meta">{{onlineMeta}}</view>
      </view>
    </view>

    <view class="assistant-panel">
      <view class="assistant-panel-title">{{previewTitle}}</view>
      <view class="assistant-bubble-row">
        <view class="assistant-avatar">AI</view>
        <view class="assistant-bubble">{{previewMessage}}</view>
      </view>
      <view class="assistant-cta-row">
        <view class="assistant-cta" bindtap="openTopicPlanner">{{ctaText}}</view>
      </view>
    </view>

    <view class="assistant-input-row">
      <view class="assistant-input-placeholder">{{inputPlaceholder}}</view>
      <view class="assistant-send" bindtap="openBusinessAdvisor">发送</view>
    </view>
  </view>
</view>
