<view class="reading-page">
  <view class="reading-shell" style="padding-top: {{statusBarHeight + 8}}px;">
    <view class="reading-hero">
      <view class="reading-hero-eyebrow">{{heroEyebrow}}</view>
      <view class="reading-hero-title">{{heroCard.title}}</view>
      <view class="reading-hero-desc">{{heroCard.description}}</view>
      <view class="reading-hero-meta-row">
        <view class="reading-hero-meta-chip {{item.dim ? 'reading-hero-meta-chip-dim' : ''}}" wx:for="{{heroMetaChips}}" wx:key="text">{{item.text}}</view>
      </view>
    </view>

    <view class="reading-featured">
      <view class="reading-featured-head">
        <view class="reading-featured-title">{{featured.sectionTitle}}</view>
        <view class="reading-featured-meta">{{featured.sectionMeta}}</view>
      </view>
      <view class="reading-featured-card" bindtap="openArticleRead">
        <view class="reading-featured-tag">{{featured.tag}}</view>
        <view class="reading-featured-card-title">{{featured.title}}</view>
        <view class="reading-featured-card-desc">{{featured.description}}</view>
      </view>
    </view>

    <view class="reading-category-row">
      <view class="reading-category-chip {{item.active ? 'reading-category-chip-active' : ''}}" wx:for="{{categoryChips}}" wx:key="text">{{item.text}}</view>
    </view>

    <view class="reading-list-card">
      <view class="reading-list-head">
        <view class="reading-list-title">继续阅读</view>
        <view class="reading-list-hint">滑动可看更多</view>
      </view>
      <view class="reading-list-wrap">
        <scroll-view class="reading-list-scroll" scroll-y="true" show-scrollbar="true">
          <view class="reading-item" wx:for="{{readingItems}}" wx:key="index">
            <view class="reading-item-index {{item.toneClass}}">{{item.index}}</view>
            <view class="reading-item-body">
              <view class="reading-item-title">{{item.title}}</view>
              <view class="reading-item-desc">{{item.desc}}</view>
              <view class="reading-item-meta-row">
                <view class="reading-item-meta {{item.metaClass}}">{{item.meta}}</view>
                <view class="reading-item-action" bindtap="openArticleRead" data-article-id="{{item.articleId}}">查看</view>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>
</view>
