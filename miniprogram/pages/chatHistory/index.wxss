/* 聊天记录页面样式 */
.container {
  padding: 0 32rpx calc(64rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background:
    radial-gradient(circle at 84% 8%, rgba(122, 109, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #f8f8ff 0%, #f4f5ff 62%, #eef1ff 100%);
  box-sizing: border-box;
}

.header {
  background: transparent;
  padding: 32rpx 0 24rpx;
  display: flex;
  justify-content: flex-start;
  position: relative;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #111827;
}

.chat-list {
  padding: 0;
}

.chat-item {
  background-color: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(121, 131, 180, 0.08);
}

.chat-date {
  font-size: 24rpx;
  color: #8f95af;
  margin-bottom: 16rpx;
}

.chat-content {
  display: flex;
  flex-direction: column;
}

.chat-question {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 700;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.chat-answer {
  font-size: 24rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.chat-status {
  font-size: 24rpx;
  color: #8f95af;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-chat-btn {
  background: linear-gradient(135deg, #7267ff 0%, #5a4cff 100%);
  color: #fff;
  font-size: 28rpx;
  width: 280rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 24rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.76);
  z-index: 999;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #7267ff;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
} 
