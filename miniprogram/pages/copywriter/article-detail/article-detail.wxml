<view class="detail-page">
  <view class="detail-orb"></view>
  <view class="detail-stack" wx:if="{{article}}">
    <view class="detail-content">
      <view class="detail-title-card">
        <view class="detail-topic-label">选题</view>
        <view class="detail-title">{{article.title}}</view>
      </view>

      <view class="detail-editor-card">
        <view class="detail-editor-head">
          <view class="detail-editor-title">正文 · 已自动保存</view>
          <view class="detail-save-status">{{saveStatus}}</view>
        </view>
        <textarea class="detail-editor-input" maxlength="-1" value="{{article.content}}" bindinput="handleContentInput"></textarea>
      </view>

      <view class="detail-assist-card">
        <view class="detail-assist-title">AI 辅助操作</view>
        <view class="detail-assist-row">
          <view class="detail-assist-chip" bindtap="triggerAssist" data-type="spoken">润色成更口语</view>
          <view class="detail-assist-chip" bindtap="triggerAssist" data-type="pro">润色成更专业</view>
        </view>
        <view class="detail-assist-row">
          <view class="detail-assist-chip" bindtap="triggerAssist" data-type="titles">生成 10 个标题</view>
          <view class="detail-assist-chip" bindtap="triggerAssist" data-type="summary">提炼摘要</view>
        </view>
      </view>
    </view>

    <view class="footer-row">
      <button class="btn-secondary" bindtap="goBack">返回文章列表</button>
      <button class="btn-primary" bindtap="copyArticle">复制全文</button>
    </view>
  </view>
</view>
