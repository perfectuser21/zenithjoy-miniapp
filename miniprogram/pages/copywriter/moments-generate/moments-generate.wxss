.studio-page {
  min-height: 100vh;
  padding: 24rpx 40rpx calc(36rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f7faff 0%, #eef4ff 100%);
  box-sizing: border-box;
}

.studio-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.page-badge {
  align-self: flex-start;
  padding: 0 16rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.8);
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 700;
}

.studio-hero,
.studio-card {
  border-radius: 36rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.studio-hero {
  background: linear-gradient(135deg, #1847d8 0%, #4263eb 58%, #16a3b7 100%);
  box-shadow: 0 22rpx 46rpx rgba(36, 71, 176, 0.2);
}

.studio-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e3eaf5;
}

.studio-card-cyan {
  background: linear-gradient(180deg, #f3fafd 0%, #ecf7fb 100%);
  border-color: #d6eef3;
}

.studio-hero-kicker {
  font-size: 23rpx;
  color: #ddebff;
  font-weight: 600;
}

.studio-hero-title {
  margin-top: 8rpx;
  font-size: 38rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 700;
}

.studio-hero-desc {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #e6f4ff;
}

.section-head,
.bottom-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-title {
  font-size: 31rpx;
  color: #0f172a;
  font-weight: 700;
}

.section-title-cyan {
  color: #0f3d4a;
}

.section-meta {
  font-size: 19rpx;
  color: #98a2b3;
  font-weight: 600;
}

.section-text {
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.48;
  color: #425466;
}

.chip-row {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
}

.chip-row-double .chip {
  flex: 1;
}

.chip {
  flex: 1;
  min-height: 60rpx;
  padding: 0 12rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  font-size: 23rpx;
  font-weight: 700;
  background: #f4f7fd;
  color: #445164;
  border: 1rpx solid #e4ebf5;
}

.chip-accent {
  background: linear-gradient(180deg, #315cff 0%, #5b7cff 100%);
  color: #ffffff;
  border: none;
}

.chip-muted {
  background: #ffffff;
  color: #344054;
}

.chip-violet {
  background: #ede7ff;
  color: #7a4edc;
  border: none;
}

.chip-light {
  background: #ffffffcc;
  color: #445164;
}

.chip-sky {
  background: #ddf4f8;
  color: #178fa3;
  border-color: #b9e7ef;
}

.chip-teal {
  background: linear-gradient(180deg, #178fa3 0%, #37b4c6 100%);
  color: #ffffff;
  border: none;
}

.bottom-actions {
  margin-top: 4rpx;
  align-items: stretch;
}

.btn,
.btn-secondary {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.btn {
  background: linear-gradient(90deg, #2e5bff 0%, #0fa6b8 100%);
  color: #ffffff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.92);
  color: #445164;
  border: 1rpx solid #d4dce8;
}

.btn::after,
.btn-secondary::after {
  border: none;
}
