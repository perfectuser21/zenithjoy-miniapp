<view class="profile-page">
  <view class="profile-orb"></view>
  <view class="profile-stack">
    <view class="profile-content">
      <view class="profile-hero">
        <view class="profile-kicker">{{heroCard.kicker}}</view>
        <view class="profile-title">{{heroCard.title}}</view>
        <view class="profile-line"></view>
        <view class="profile-desc">{{heroCard.description}}</view>
      </view>

      <view class="info-card">
        <view class="tag tag-audience">目标人群</view>
        <textarea class="info-input compact" maxlength="-1" value="{{audienceText}}" bindinput="handleInput" data-field="audienceText" placeholder="副业新手、宝妈、职场 3-5 年"></textarea>
      </view>

      <view class="info-card info-card-soft">
        <view class="tag tag-value">价值</view>
        <textarea class="info-input tall" maxlength="-1" value="{{valueText}}" bindinput="handleInput" data-field="valueText" placeholder="帮你在更短时间内做到更稳定的结果&#10;避开最容易浪费时间的 3 个坑&#10;用更具体的方法解决卡住行动的问题"></textarea>
      </view>

      <view class="info-card info-card-soft">
        <view class="tag tag-ip">IP</view>
        <textarea class="info-input compact" maxlength="-1" value="{{ipText}}" bindinput="handleInput" data-field="ipText" placeholder="我是做过 3 年内容增长的产品运营，偏理性拆解和实操派风格。"></textarea>
      </view>
    </view>

    <view class="footer-row">
      <button class="btn-secondary" bindtap="goBack">上一步</button>
      <button class="btn-primary" bindtap="generateTopicList">生成 5 个选题</button>
    </view>
  </view>
</view>
