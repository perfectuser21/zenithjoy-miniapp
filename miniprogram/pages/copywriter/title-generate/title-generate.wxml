<view class="title-page">
  <view class="title-orb"></view>
  <view class="title-stack">
    <view class="title-content">
      <view class="title-hero">
        <view class="title-hero-kicker">{{heroCard.kicker}}</view>
        <view class="title-hero-title">{{heroCard.title}}</view>
        <view class="title-hero-desc">{{heroCard.description}}</view>
      </view>

      <view class="title-card title-source-card">
        <view class="section-label">正文</view>
        <view class="section-text">{{sourceContext.articleContent}}</view>
      </view>

      <view class="title-card">
        <view class="section-head">
          <view class="section-title">标题风格</view>
          <view class="section-meta">可多次切换</view>
        </view>
        <view class="style-row" wx:for="{{titleStyles}}" wx:key="index">
          <view
            class="style-chip {{activeStyle === label ? 'style-chip-active' : ''}}"
            wx:for="{{item}}"
            wx:key="*this"
            wx:for-item="label"
            data-style="{{label}}"
            bindtap="handleStyleSelect"
          >
            {{label}}
          </view>
        </view>
      </view>

      <view class="title-card title-results-card">
        <view class="section-head">
          <view class="section-title">本轮标题结果</view>
          <view class="section-meta">{{activeStyle}} · {{results.length}} 条</view>
        </view>

        <view class="result-list">
          <view
            class="result-card {{item.id === activeResultId ? 'result-card-active' : ''}}"
            wx:for="{{visibleResults}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="selectResult"
          >
            <view class="result-title">{{item.text}}</view>
            <view class="result-note">{{item.note}}</view>
          </view>
        </view>

        <view class="result-track">
          <view class="result-thumb"></view>
        </view>

        <view class="inline-actions">
          <view class="inline-action" bindtap="regenerateBatch">换一批</view>
          <view class="inline-action inline-action-primary" bindtap="openLibrary">添加到标题备选库</view>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="btn-secondary" bindtap="goBack">返回创作页</button>
      <button class="btn-primary" bindtap="confirmTitle">复制该标题</button>
    </view>
  </view>
</view>
