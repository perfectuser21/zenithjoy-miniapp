.title-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f6f7fe 0%, #eef2ff 100%);
  overflow: hidden;
}

.title-orb {
  position: absolute;
  top: 110rpx;
  right: -76rpx;
  width: 288rpx;
  height: 288rpx;
  border-radius: 50%;
  background: rgba(215, 223, 255, 0.2);
  filter: blur(20rpx);
}

.title-stack {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 16rpx 40rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.title-content {
  display: flex;
  flex: 1;
  min-height: 0;
  flex-direction: column;
  gap: 20rpx;
  overflow: hidden;
}

.title-hero,
.title-card {
  border-radius: 44rpx;
  box-sizing: border-box;
}

.title-hero {
  padding: 35rpx;
  background: linear-gradient(135deg, #243bce 0%, #5a4cff 100%);
  box-shadow: 0 24rpx 48rpx rgba(58, 79, 182, 0.2);
  border: 1rpx solid rgba(207, 214, 255, 0.26);
}

.title-hero-kicker {
  font-size: 27rpx;
  font-weight: 600;
  color: #e1e8ff;
}

.title-hero-title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #ffffff;
}

.title-hero-desc {
  margin-top: 10rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #e7ecff;
}

.title-card {
  position: relative;
  padding: 27rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(84, 104, 167, 0.09);
  border: 1rpx solid #d9e2ff;
}

.title-source-card {
  min-height: 234rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-label {
  font-size: 31rpx;
  font-weight: 600;
  color: #2947d3;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #101828;
}

.section-meta {
  font-size: 23rpx;
  font-weight: 600;
  color: #7a7e9a;
}

.section-text {
  margin-top: 12rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #667085;
}

.style-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.style-chip {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 20rpx;
  background: #eef1ff;
  color: #5063c7;
  font-size: 25rpx;
  font-weight: 700;
}

.style-chip-active {
  background: #8f87ff;
  color: #ffffff;
}

.title-results-card {
  min-height: 0;
  padding-right: 30rpx;
}

.result-list {
  margin-top: 16rpx;
  padding-right: 10rpx;
  box-sizing: border-box;
}

.result-card {
  padding: 23rpx 27rpx;
  border-radius: 35rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7f0;
}

.result-card + .result-card {
  margin-top: 16rpx;
}

.result-card-active {
  background: #eef3ff;
  border-color: transparent;
}

.result-title {
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #101828;
}

.result-note {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #667085;
}

.result-track {
  position: absolute;
  top: 96rpx;
  right: 18rpx;
  width: 8rpx;
  height: 254rpx;
  border-radius: 999rpx;
  background: #eef2ff;
}

.result-thumb {
  width: 100%;
  height: 84rpx;
  border-radius: 999rpx;
  background: #7c8bff;
}

.inline-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.inline-action {
  flex: 1;
  height: 69rpx;
  line-height: 69rpx;
  text-align: center;
  border-radius: 23rpx;
  background: #f5f7ff;
  color: #4b5fd0;
  font-size: 25rpx;
  font-weight: 700;
}

.inline-action-primary {
  background: #eef2ff;
  color: #2947d3;
}

.bottom-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  gap: 16rpx;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 81rpx;
  line-height: 81rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 700;
  padding: 0;
  box-sizing: border-box;
}

.btn-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.btn-primary {
  background: linear-gradient(180deg, #6e65ff 0%, #314fdb 100%);
  color: #ffffff;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}
