@import "../common.wxss";

.studio-page {
  min-height: 100vh;
  padding: 16rpx 20rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f6f7fe 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.studio-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.studio-toolbar,
.section-head,
.bottom-actions,
.footer-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.toolbar-btn,
.toolbar-tag {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.toolbar-btn {
  background: rgba(255, 255, 255, 0.8);
  color: #344054;
}

.toolbar-tag {
  background: rgba(255, 255, 255, 0.86);
  color: #4f46e5;
}

.studio-hero,
.studio-card {
  border-radius: 40rpx;
  box-sizing: border-box;
}

.studio-hero {
  padding: 34rpx 32rpx;
  background: linear-gradient(135deg, #243bce 0%, #5a4cff 100%);
  box-shadow: 0 24rpx 48rpx rgba(58, 79, 182, 0.2);
}

.studio-hero-kicker {
  font-size: 25rpx;
  color: #e1e8ff;
  font-weight: 600;
}

.studio-hero-title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.24;
  color: #ffffff;
  font-weight: 700;
}

.studio-hero-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.45;
  color: #e7ecff;
}

.studio-card {
  position: relative;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 18rpx 36rpx rgba(84, 104, 167, 0.09);
}

.section-label,
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #101828;
}

.section-meta {
  font-size: 22rpx;
  font-weight: 600;
  color: #7a7e9a;
}

.section-text {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.5;
  color: #667085;
}

.chip-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.chip {
  flex: 1;
  height: 58rpx;
  border-radius: 18rpx;
  background: #eef1ff;
  color: #5063c7;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.chip-active {
  background: #8f87ff;
  color: #ffffff;
}

.studio-card-results {
  padding-right: 34rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 14rpx;
}

.result-card {
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7f0;
}

.result-card-active {
  background: #eef3ff;
  border-color: #d9e2ff;
}

.result-title {
  font-size: 32rpx;
  line-height: 1.34;
  color: #101828;
  font-weight: 700;
}

.result-note {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
}

.result-tag {
  margin-top: 10rpx;
  width: fit-content;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f4eeff;
  color: #7a4edc;
  font-size: 20rpx;
  font-weight: 700;
}

.fake-scrollbar {
  position: absolute;
  top: 84rpx;
  right: 12rpx;
  width: 8rpx;
  height: 250rpx;
  border-radius: 999rpx;
  background: #eef2ff;
}

.fake-scrollbar-thumb {
  width: 100%;
  height: 86rpx;
  border-radius: 999rpx;
  background: #7c8bff;
}

.footer-actions,
.bottom-actions {
  margin-top: 14rpx;
}

.ghost-action {
  flex: 1;
  height: 72rpx;
  border-radius: 24rpx;
  background: #f5f7ff;
  color: #4b5fd0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.ghost-action-primary {
  background: #eef2ff;
  color: #2947d3;
}
