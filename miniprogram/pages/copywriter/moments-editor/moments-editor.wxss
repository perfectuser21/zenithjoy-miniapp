.editor-page {
  min-height: 100vh;
  padding: 16rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f6f7fe 0%, #eef2ff 100%);
  box-sizing: border-box;
}

.editor-stack {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-height: calc(100vh - 16rpx - 24rpx - env(safe-area-inset-bottom));
}

.page-badge {
  align-self: flex-start;
  padding: 0 16rpx;
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.8);
  color: #ffffff;
  font-size: 19rpx;
  font-weight: 700;
}

.hero-card,
.panel-card {
  border-radius: 32rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(135deg, #243bce 0%, #5a4cff 100%);
  box-shadow: 0 20rpx 44rpx rgba(49, 79, 219, 0.2);
}

.panel-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e3eaf5;
}

.panel-card-flex {
  flex: 1;
  min-height: 0;
}

.hero-kicker {
  font-size: 21rpx;
  color: #e1e8ff;
  font-weight: 600;
}

.hero-title {
  margin-top: 6rpx;
  font-size: 35rpx;
  line-height: 1.22;
  color: #ffffff;
  font-weight: 700;
}

.hero-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.4;
  color: #e7ecff;
}

.section-head,
.bottom-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.section-title {
  font-size: 31rpx;
  color: #0f172a;
  font-weight: 700;
}

.section-meta {
  font-size: 19rpx;
  color: #98a2b3;
  font-weight: 600;
}

.guide-row {
  display: flex;
  gap: 8rpx;
  margin-top: 8rpx;
}

.guide-chip {
  flex: 1;
  height: 50rpx;
  line-height: 50rpx;
  text-align: center;
  border-radius: 20rpx;
  background: #eef3ff;
  color: #4e63ca;
  font-size: 23rpx;
  font-weight: 700;
}

.guide-chip-active {
  background: #dce7ff;
}

.draft-scroll {
  margin-top: 10rpx;
  height: 440rpx;
}

.draft-card {
  padding: 14rpx 16rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid #dce3f7;
}

.draft-card + .draft-card {
  margin-top: 10rpx;
}

.draft-card-active {
  background: #eef3ff;
  border-color: #9db7ff;
}

.draft-content {
  font-size: 23rpx;
  line-height: 1.46;
  color: #1d2939;
}

.draft-meta {
  margin-top: 8rpx;
  font-size: 19rpx;
  color: #315cff;
  font-weight: 600;
}

.editor-input {
  width: 100%;
  height: 146rpx;
  margin-top: 10rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #f8faff;
  border: 1rpx solid #dde3f2;
  box-sizing: border-box;
  font-size: 23rpx;
  line-height: 1.5;
  color: #101828;
}

.bottom-actions {
  margin-top: auto;
  align-items: stretch;
}

.btn,
.btn-secondary {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.btn {
  background: linear-gradient(180deg, #6e65ff 0%, #314fdb 100%);
  color: #ffffff;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.92);
  color: #445164;
  border: 1rpx solid #d0d5dd;
}

.btn::after,
.btn-secondary::after {
  border: none;
}
