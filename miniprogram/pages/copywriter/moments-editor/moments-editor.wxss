@import "../common.wxss";

.editor-page {
  min-height: 100vh;
  padding: 16rpx 20rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f5f8ff 0%, #eef3ff 100%);
  box-sizing: border-box;
}

.editor-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.toolbar-row,
.section-head,
.bottom-actions,
.action-row,
.recommend-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.toolbar-btn,
.toolbar-tag {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.toolbar-btn {
  background: rgba(255, 255, 255, 0.85);
  color: #344054;
}

.toolbar-tag {
  background: rgba(255, 255, 255, 0.92);
  color: #3151d7;
}

.hero-card,
.panel-card {
  border-radius: 36rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(130deg, #1e40af 0%, #4338ca 55%, #4f46e5 100%);
  box-shadow: 0 22rpx 46rpx rgba(41, 71, 160, 0.2);
}

.hero-kicker {
  font-size: 24rpx;
  color: #e6edff;
  font-weight: 600;
}

.hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 700;
}

.hero-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #e7edff;
}

.section-title {
  font-size: 30rpx;
  color: #101828;
  font-weight: 700;
}

.section-meta {
  font-size: 22rpx;
  color: #667085;
  font-weight: 600;
}

.featured-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 12rpx;
}

.draft-card {
  border-radius: 26rpx;
  padding: 22rpx;
  border: 2rpx solid #dce3f7;
  background: #ffffff;
}

.draft-card-active {
  background: #eef3ff;
  border-color: #9db7ff;
}

.draft-content,
.recommend-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #1d2939;
}

.draft-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #667085;
}

.rest-scroll {
  margin-top: 12rpx;
  max-height: 360rpx;
}

.rest-card + .rest-card {
  margin-top: 12rpx;
}

.editor-input {
  width: 100%;
  min-height: 260rpx;
  margin-top: 12rpx;
  border-radius: 24rpx;
  background: #f8faff;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.6;
  color: #101828;
}

.action-row {
  margin-top: 14rpx;
  justify-content: flex-start;
  flex-wrap: wrap;
}

.action-chip {
  height: 66rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #f2f4f7;
  color: #344054;
  font-size: 23rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-chip-primary {
  background: #e7edff;
  color: #2e4bc7;
}

.recommend-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.recommend-item {
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  background: #f9fbff;
  border: 2rpx solid #e4e7ec;
}

.recommend-tag {
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #3151d7;
  background: #e3ebff;
  font-weight: 700;
}

.recommend-text {
  margin-top: 10rpx;
}

.recommend-actions {
  margin-top: 12rpx;
  justify-content: flex-end;
}

.recommend-btn {
  min-width: 108rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #edf1ff;
  color: #2d4cc8;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recommend-btn-primary {
  background: #2d4cc8;
  color: #ffffff;
}

.bottom-actions {
  align-items: stretch;
}
