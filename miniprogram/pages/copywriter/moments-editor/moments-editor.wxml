<view class="editor-page">
  <view class="editor-stack">
    <view class="toolbar-row">
      <view class="toolbar-btn" bindtap="goBackToPreview">返回预览</view>
      <view class="toolbar-tag">朋友圈文案精修</view>
    </view>

    <view class="hero-card">
      <view class="hero-kicker">下一步：文案定稿</view>
      <view class="hero-title">先看 3 条重点版本，再编辑出最终可发文案</view>
      <view class="hero-desc">支持复制、粘贴、替换推荐句，并可返回上一层重新生成额度。</view>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <view class="section-title">重点预览（3 条）</view>
        <view class="section-meta">点击切换编辑目标</view>
      </view>
      <view class="featured-list">
        <view
          class="draft-card {{item.id === selectedDraftId ? 'draft-card-active' : ''}}"
          wx:for="{{featuredDrafts}}"
          wx:key="id"
          bindtap="selectDraft"
          data-id="{{item.id}}"
        >
          <view class="draft-content">{{item.content}}</view>
          <view class="draft-meta">{{item.meta}}</view>
        </view>
      </view>
    </view>

    <view class="panel-card" wx:if="{{restDrafts.length}}">
      <view class="section-head">
        <view class="section-title">其他版本</view>
        <view class="section-meta">滚动浏览</view>
      </view>
      <scroll-view class="rest-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
        <view
          class="draft-card rest-card {{item.id === selectedDraftId ? 'draft-card-active' : ''}}"
          wx:for="{{restDrafts}}"
          wx:key="id"
          bindtap="selectDraft"
          data-id="{{item.id}}"
        >
          <view class="draft-content">{{item.content}}</view>
          <view class="draft-meta">{{item.meta}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <view class="section-title">文案修改</view>
        <view class="section-meta">可直接编辑</view>
      </view>
      <textarea
        class="editor-input"
        maxlength="-1"
        auto-height="true"
        value="{{activeContent}}"
        bindinput="handleContentInput"
        placeholder="在这里调整语气、结构和结尾 CTA"
      />
      <view class="action-row">
        <view class="action-chip" bindtap="pasteFromClipboard">粘贴内容</view>
        <view class="action-chip action-chip-primary" bindtap="copyCurrent">复制当前</view>
        <view class="action-chip" bindtap="saveCurrentVersion">保存修改</view>
      </view>
    </view>

    <view class="panel-card">
      <view class="section-head">
        <view class="section-title">备选推荐</view>
        <view class="section-meta">一键替换 / 追加</view>
      </view>
      <view class="recommend-list">
        <view class="recommend-item" wx:for="{{recommendations}}" wx:key="id">
          <view class="recommend-tag">{{item.tag}}</view>
          <view class="recommend-text">{{item.text}}</view>
          <view class="recommend-actions">
            <view class="recommend-btn" bindtap="applyRecommendation" data-text="{{item.text}}" data-mode="append">追加</view>
            <view class="recommend-btn recommend-btn-primary" bindtap="applyRecommendation" data-text="{{item.text}}" data-mode="replace">替换</view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="btn-secondary" bindtap="goBackToGenerate">返回上一层重新生成</button>
      <button class="btn" bindtap="copyCurrent">复制定稿</button>
    </view>
  </view>
</view>
