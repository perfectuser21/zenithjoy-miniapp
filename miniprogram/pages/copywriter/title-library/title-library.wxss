.library-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f6f7fe 0%, #eef2ff 100%);
  overflow: hidden;
}

.library-orb {
  position: absolute;
  top: 110rpx;
  right: -76rpx;
  width: 288rpx;
  height: 288rpx;
  border-radius: 50%;
  background: rgba(215, 223, 255, 0.2);
  filter: blur(20rpx);
}

.library-stack {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 16rpx 40rpx calc(118rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.library-content {
  display: flex;
  flex: 1;
  min-height: 0;
  flex-direction: column;
  gap: 14rpx;
  overflow: hidden;
}

.library-hero,
.library-card {
  border-radius: 40rpx;
  box-sizing: border-box;
}

.library-hero {
  padding: 27rpx;
  background: linear-gradient(135deg, #243bce 0%, #5a4cff 100%);
  box-shadow: 0 24rpx 48rpx rgba(58, 79, 182, 0.2);
  border: 1rpx solid rgba(207, 214, 255, 0.26);
}

.library-hero-kicker {
  font-size: 27rpx;
  font-weight: 600;
  color: #e1e8ff;
}

.library-hero-title {
  margin-top: 8rpx;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #ffffff;
}

.library-hero-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.35;
  color: #e7ecff;
}

.library-card {
  position: relative;
  padding: 23rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(84, 104, 167, 0.09);
  border: 1rpx solid #d9e2ff;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #101828;
}

.section-meta {
  font-size: 23rpx;
  font-weight: 600;
  color: #7a7e9a;
}

.library-filter-card {
  min-height: 178rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.filter-chip {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 20rpx;
  background: #eef1ff;
  color: #5063c7;
  font-size: 23rpx;
  font-weight: 700;
}

.filter-chip-active {
  background: #8f87ff;
  color: #ffffff;
}

.library-list-card {
  flex: 1;
  min-height: 0;
  padding-right: 28rpx;
}

.library-scroll {
  height: 380rpx;
  margin-top: 14rpx;
  padding-right: 10rpx;
  box-sizing: border-box;
}

.library-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.library-item {
  padding: 23rpx 27rpx;
  border-radius: 35rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7f0;
}

.library-item-active {
  background: #eef3ff;
  border-color: transparent;
}

.library-item-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.library-item-title {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #101828;
}

.library-item-note {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #667085;
}

.status-pill {
  align-self: flex-start;
  padding: 8rpx 19rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
}

.status-locked,
.status-confirmed {
  background: #dde6ff;
  color: #3151d7;
}

.status-compare {
  background: #f4eeff;
  color: #7a4edc;
}

.status-saved {
  background: #eef6ff;
  color: #4b6fcf;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.item-action {
  flex: 1;
  height: 62rpx;
  line-height: 62rpx;
  text-align: center;
  border-radius: 19rpx;
  font-size: 23rpx;
  font-weight: 700;
}

.item-action-primary {
  background: #e7edff;
  color: #3151d7;
}

.item-action-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d5dbea;
  box-sizing: border-box;
}

.library-track {
  position: absolute;
  top: 88rpx;
  right: 18rpx;
  width: 6rpx;
  height: 472rpx;
  border-radius: 999rpx;
  background: #eef2ff;
}

.library-thumb {
  width: 100%;
  height: 82rpx;
  border-radius: 999rpx;
  background: #7c8bff;
}

.final-card {
  padding: 19rpx;
}

.final-panel {
  margin-top: 12rpx;
  padding: 19rpx 23rpx;
  border-radius: 35rpx;
  background: linear-gradient(180deg, #eef3ff 0%, #f8faff 100%);
  border: 1rpx solid #d9e2ff;
}

.final-title {
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #101828;
}

.final-note {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: #667085;
}

.final-tags {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.mini-tag {
  padding: 8rpx 19rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
}

.mini-tag-blue {
  background: #dde6ff;
  color: #3151d7;
}

.mini-tag-purple {
  background: #f4eeff;
  color: #7a4edc;
}

.mini-tag-sky {
  background: #eef6ff;
  color: #4b6fcf;
}

.copy-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.copy-btn {
  padding: 10rpx 19rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.8);
  color: #3151d7;
  font-size: 23rpx;
  font-weight: 700;
  border: 1rpx solid #c9d7ff;
}

.bottom-actions {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  z-index: 20;
  display: flex;
  gap: 16rpx;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 81rpx;
  line-height: 81rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 700;
  padding: 0;
  box-sizing: border-box;
}

.btn-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.btn-primary {
  background: linear-gradient(180deg, #6e65ff 0%, #314fdb 100%);
  color: #ffffff;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}
