<view class="library-page">
  <view class="library-orb"></view>
  <view class="library-stack">
    <view class="library-content">
      <view class="library-hero">
        <view class="library-hero-kicker">{{heroCard.kicker}}</view>
        <view class="library-hero-title">{{heroCard.title}}</view>
        <view class="library-hero-desc">{{heroCard.description}}</view>
      </view>

      <view class="library-card library-filter-card">
        <view class="section-head">
          <view class="section-title">筛选视图</view>
          <view class="section-meta">自动按状态整理</view>
        </view>
        <view class="filter-row">
          <view class="filter-chip filter-chip-active">全部 {{stats.all}}</view>
          <view class="filter-chip">已锁定 {{stats.locked}}</view>
          <view class="filter-chip">待比较 {{stats.compare}}</view>
        </view>
      </view>

      <view class="library-card library-list-card">
        <view class="section-head">
          <view class="section-title">我的备选标题</view>
          <view class="section-meta">可继续补充</view>
        </view>

        <scroll-view class="library-scroll" scroll-y="true" show-scrollbar="false">
          <view class="library-list">
            <view class="library-item {{index === 0 ? 'library-item-active' : ''}}" wx:for="{{items}}" wx:key="id">
              <view class="library-item-head">
                <view class="library-item-title">{{item.text}}</view>
                <view class="status-pill {{item.className}}">{{item.label}}</view>
              </view>
              <view class="library-item-note">{{item.note}}</view>
              <view class="item-actions">
                <view class="item-action {{item.status === 'locked' ? 'item-action-secondary' : 'item-action-primary'}}" bindtap="toggleStatus" data-id="{{item.id}}">
                  {{item.actionText}}
                </view>
                <view class="item-action {{item.status === 'locked' ? 'item-action-primary' : 'item-action-secondary'}}" bindtap="removeItem" data-id="{{item.id}}">
                  删除
                </view>
              </view>
            </view>
          </view>
        </scroll-view>

        <view class="library-track">
          <view class="library-thumb"></view>
        </view>
      </view>

      <view class="library-card final-card" wx:if="{{finalTitle}}">
        <view class="section-head">
          <view class="section-title">最终选题</view>
          <view class="status-pill status-confirmed">已确认 1 条</view>
        </view>
        <view class="final-panel">
          <view class="final-title">{{finalTitle.text}}</view>
          <view class="final-note">适合作为本轮主标题，冲突感强，点击意图明确。</view>
          <view class="final-tags">
            <view class="mini-tag mini-tag-blue">主标题</view>
            <view class="mini-tag mini-tag-purple">冲突型</view>
            <view class="mini-tag mini-tag-sky">优先发布</view>
          </view>
          <view class="copy-row">
            <view class="copy-btn" bindtap="copyFinalTitle">复制标题</view>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="btn-secondary" bindtap="continueAdd">继续添加</button>
      <button class="btn-primary" bindtap="backToStudio">返回创作页</button>
    </view>
  </view>
</view>
