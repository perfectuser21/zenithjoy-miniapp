<view class="articles-page">
  <view class="articles-orb"></view>
  <view class="articles-stack" wx:if="{{topic}}">
    <view class="articles-content">
      <view class="articles-hero">
        <view class="articles-kicker">{{heroCard.kicker}}</view>
        <view class="articles-title">{{topic.title || heroCard.title}}</view>
        <view class="articles-desc">摘要：{{topic.summary || heroCard.description}}</view>
      </view>

      <view class="articles-loading-chip" wx:if="{{generating}}">正在生成第 1/3 篇…… 支持单篇重试</view>

      <scroll-view class="articles-scroll" scroll-y="true" show-scrollbar="true">
        <view class="article-card" wx:for="{{previewCards}}" wx:key="articleId">
          <view class="article-title">{{item.versionTag}} · {{item.variantLabel}}</view>
          <view class="article-desc">{{item.previewText}}</view>
          <view class="article-action" bindtap="openArticleDetail" data-id="{{item.articleId}}">查看并编辑</view>
        </view>
      </scroll-view>
    </view>

    <view class="footer-row">
      <button class="btn-secondary" bindtap="goBack">返回继续修改</button>
      <button class="btn-primary" bindtap="useSelected" loading="{{generating}}" disabled="{{generating}}">使用此篇并进入精修</button>
    </view>
  </view>
</view>
