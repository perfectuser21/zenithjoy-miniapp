.articles-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f7ff 0%, #eef3ff 100%);
  overflow: hidden;
}

.articles-orb {
  position: absolute;
  top: 122rpx;
  right: -68rpx;
  width: 296rpx;
  height: 296rpx;
  border-radius: 50%;
  background: rgba(213, 222, 255, 0.2);
  filter: blur(20rpx);
}

.articles-stack {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 40rpx calc(142rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.articles-content {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  overflow: hidden;
}

.articles-hero {
  border-radius: 56rpx;
  padding: 24rpx 26rpx;
  background: linear-gradient(135deg, #1e40af 0%, #3157d5 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.articles-kicker {
  font-size: 23rpx;
  color: #dde5ff;
  font-weight: 600;
}

.articles-title {
  font-size: 40rpx;
  line-height: 1.25;
  color: #ffffff;
  font-weight: 700;
}

.articles-desc {
  font-size: 23rpx;
  line-height: 1.5;
  color: #e4eaff;
}

.articles-loading-chip {
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #e9f0ff;
  color: #2947d3;
  font-size: 21rpx;
  font-weight: 600;
}

.articles-scroll {
  flex: 1;
  min-height: 0;
}

.article-card {
  border-radius: 48rpx;
  background: #ffffff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.article-title {
  font-size: 31rpx;
  line-height: 1.35;
  color: #101828;
  font-weight: 700;
}

.article-desc {
  font-size: 27rpx;
  line-height: 1.6;
  color: #475467;
}

.article-action {
  align-self: flex-end;
  margin-top: 4rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #e9f0ff;
  color: #2947d3;
  font-size: 23rpx;
  font-weight: 700;
}

.footer-row {
  display: flex;
  gap: 16rpx;
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: block;
  padding: 0;
}

.btn-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.btn-primary {
  background: #2947d3;
  color: #ffffff;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}
