<view class="ideas-page">
  <view class="ideas-orb"></view>
  <view class="ideas-stack">
    <view class="ideas-content">
      <view class="ideas-hero">
        <view class="ideas-kicker">{{heroCard.kicker}}</view>
        <view class="ideas-title">{{heroCard.title}}</view>
        <view class="ideas-line"></view>
        <view class="ideas-desc">{{heroCard.description}}</view>
      </view>

      <view class="ideas-card">
        <textarea
          class="ideas-input"
          maxlength="-1"
          value="{{ideasText}}"
          bindinput="handleIdeasInput"
          placeholder="例如：我想写普通人做内容时最容易踩的坑，以及为什么总是卡在持续输出这一步。"
        />
      </view>

      <view class="save-status">{{saveStatus}}</view>
    </view>

    <view class="footer-row">
      <button class="btn-secondary" bindtap="goBack">上一步</button>
      <button class="btn-primary" bindtap="goNext">继续完善资料</button>
    </view>
  </view>
</view>
