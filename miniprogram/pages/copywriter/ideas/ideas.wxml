<view class="page">
  <view class="stack">
    <view class="progress">
      <view class="progress-main">找方向 / 选题 / 出成稿</view>
      <view class="progress-step">2 / 6</view>
    </view>

    <view class="hero">
      <view class="kicker">STEP 2</view>
      <view class="title">补充你的想法</view>
      <view class="desc">告诉我你想表达什么、想要什么风格，我会把它变成更清晰的选题。</view>
    </view>

    <view class="card">
      <view class="label">你想表达什么</view>
      <textarea class="textarea" maxlength="-1" value="{{ideasText}}" bindinput="handleIdeasInput" placeholder="例如：我想写普通人做内容时最容易踩的坑"></textarea>
    </view>

    <view class="card">
      <view class="label">你想要什么风格</view>
      <view class="row">
        <view wx:for="{{styleOptions}}" wx:key="label" class="{{item.className}}" bindtap="toggleStyle" data-value="{{item.label}}">{{item.label}}</view>
      </view>
    </view>

    <view class="card">
      <view class="label">有哪些限制</view>
      <textarea class="textarea" maxlength="-1" value="{{constraintsText}}" bindinput="handleConstraintsInput" placeholder="例如：适合公众号，1000 字左右，不要太鸡汤"></textarea>
    </view>

    <view class="muted">{{saveStatus}}</view>

    <view class="footer">
      <button class="btn-secondary" bindtap="goBack">上一步</button>
      <button class="btn" bindtap="goNext">继续完善创作信息</button>
    </view>
  </view>
</view>
