.ideas-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f2fbfa 0%, #ebf7ff 100%);
  overflow: hidden;
}

.ideas-orb {
  position: absolute;
  top: 220rpx;
  right: -100rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(204, 251, 241, 0.2);
  filter: blur(20rpx);
}

.ideas-stack {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  gap: 16rpx;
  padding: 16rpx 40rpx calc(142rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.ideas-content {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  overflow: auto;
}

.ideas-hero {
  padding: 24rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #0f766e 0%, #0ea5a4 100%);
}

.ideas-kicker {
  font-size: 23rpx;
  color: #ccfbf1;
  font-weight: 600;
}

.ideas-title {
  margin-top: 8rpx;
  font-size: 54rpx;
  line-height: 1.16;
  color: #ffffff;
  font-weight: 700;
}

.ideas-line {
  width: 100%;
  height: 2rpx;
  margin-top: 12rpx;
  background: rgba(216, 255, 250, 0.35);
}

.ideas-desc {
  margin-top: 12rpx;
  font-size: 29rpx;
  line-height: 1.5;
  color: #d4f9f2;
}

.ideas-card {
  min-height: 1028rpx;
  padding: 20rpx;
  border-radius: 48rpx;
  background: #ffffff;
}

.ideas-input {
  width: 100%;
  min-height: 988rpx;
  font-size: 31rpx;
  line-height: 1.7;
  color: #344054;
}

.save-status {
  font-size: 23rpx;
  color: #0f766e;
  font-weight: 600;
}

.footer-row {
  display: flex;
  gap: 16rpx;
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: block;
  padding: 0;
}

.btn-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.btn-primary {
  background: #2947d3;
  color: #ffffff;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}
