@import "../common.wxss";

.topic-results {
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 18rpx 40rpx rgba(85, 105, 168, 0.08);
  backdrop-filter: blur(18rpx);
}

.topic-results-header {
  margin-bottom: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #344054;
}

.topic-scroll-shell {
  position: relative;
  padding-right: 18rpx;
}

.topic-scroll {
  height: 980rpx;
}

.topic-list-inner {
  padding-right: 8rpx;
  box-sizing: border-box;
}

.topic-scrollbar {
  position: absolute;
  top: 8rpx;
  right: 0;
  bottom: 8rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.2);
  overflow: hidden;
}

.topic-scrollbar-thumb {
  width: 100%;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #6d5efc 0%, #3388ff 100%);
}
