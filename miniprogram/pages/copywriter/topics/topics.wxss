.topics-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7ff 0%, #eef2ff 100%);
  overflow: hidden;
}

.topics-orb {
  position: absolute;
  top: 118rpx;
  right: -70rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(203, 215, 255, 0.2);
  filter: blur(20rpx);
}

.topics-stack {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 16rpx 40rpx calc(142rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.topics-content {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  overflow: hidden;
}

.topics-hero {
  border-radius: 56rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, #243bce 0%, #3858f2 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.topics-kicker {
  font-size: 23rpx;
  color: #dfe6ff;
  font-weight: 600;
}

.topics-title {
  font-size: 50rpx;
  line-height: 1.2;
  color: #ffffff;
  font-weight: 700;
}

.topics-desc {
  font-size: 23rpx;
  line-height: 1.5;
  color: #e2e8ff;
}

.summary-card {
  padding: 28rpx;
  border-radius: 44rpx;
  background: #ffffff;
}

.summary-text {
  font-size: 23rpx;
  line-height: 1.6;
  color: #475467;
}

.topic-scroll {
  flex: 1;
  min-height: 0;
}

.topic-card {
  border-radius: 48rpx;
  background: #ffffff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.topic-card-active {
  background: #e9f0ff;
  border: 1rpx solid #b7cbff;
}

.topic-title {
  font-size: 31rpx;
  line-height: 1.35;
  color: #101828;
  font-weight: 700;
}

.topic-meta,
.topic-desc {
  font-size: 27rpx;
  line-height: 1.6;
  color: #475467;
}

.topic-card-active .topic-meta,
.topic-card-active .topic-desc {
  color: #2947d3;
}

.notice-chip {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  text-align: center;
  background: #fff4d6;
  color: #9a6700;
  font-size: 23rpx;
  font-weight: 600;
}

.footer-row {
  display: flex;
  gap: 24rpx;
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: block;
  padding: 0;
}

.btn-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.btn-primary {
  background: #2947d3;
  color: #ffffff;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}
