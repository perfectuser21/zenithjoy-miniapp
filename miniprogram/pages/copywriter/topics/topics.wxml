<view class="topics-page">
  <view class="topics-orb"></view>
  <view class="topics-stack">
    <view class="topics-content">
      <view class="topics-hero">
        <view class="topics-kicker">{{heroCard.kicker}}</view>
        <view class="topics-title">{{heroCard.title}}</view>
        <view class="topics-desc">{{heroCard.description}}</view>
      </view>

      <view class="summary-card">
        <view class="summary-text" wx:for="{{summaryRows}}" wx:key="label">{{item.label}}：{{item.value}}</view>
      </view>

      <scroll-view class="topic-scroll" scroll-y="true" show-scrollbar="true">
        <view
          class="topic-card {{item.locked || index === 2 ? 'topic-card-active' : ''}}"
          wx:for="{{topicCards}}"
          wx:key="topicId"
          bindtap="openArticles"
          data-id="{{item.topicId}}"
        >
          <view class="topic-title">{{item.title}}</view>
          <view class="topic-meta">{{item.typeTag}} · {{item.platformTags.join(' / ')}}</view>
          <view class="topic-desc">{{item.summary}}</view>
        </view>
      </scroll-view>

      <view class="notice-chip" wx:if="{{topicsDirty || articlesDirty}}">你修改过前面的创作条件，建议重新生成</view>
    </view>

    <view class="footer-row">
      <button class="btn-secondary" bindtap="goBack">返回修改条件</button>
      <button class="btn-primary" bindtap="regenerateAll" loading="{{generating}}" disabled="{{generating}}">全部重生成</button>
    </view>
  </view>
</view>
