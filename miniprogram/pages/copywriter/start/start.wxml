<view class="start-page">
  <view class="start-orb"></view>
  <view class="start-stack">
    <view class="start-content">
      <view class="start-hero">
        <view class="start-title">{{heroCard.title}}</view>
        <view class="start-line"></view>
        <view class="start-desc">{{heroCard.description}}</view>
        <view class="start-hint">{{resumeHint}}</view>
      </view>

      <view class="flow-panel">
        <view class="panel-head">
          <view class="panel-title">本次流程</view>
          <view class="panel-meta">从关键词到定稿</view>
        </view>
        <view class="step-list">
          <view class="step-item tone-{{item.tone}}" wx:for="{{flowSteps}}" wx:key="no">
            <view class="step-no">{{item.no}}</view>
            <view class="step-label">{{item.label}}</view>
          </view>
        </view>
      </view>

      <view class="prep-card">
        <view class="panel-title panel-title-dark">开始前准备</view>
        <view class="prep-list">
          <view class="prep-item" wx:for="{{prepCards}}" wx:key="title">
            <view class="prep-title">{{item.title}}</view>
            <view class="prep-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="start-footer">
      <button class="primary-cta" bindtap="startCreation">开始文案创作</button>
    </view>
  </view>
</view>
