@import "/styles/pencil-theme.wxss";
.page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #f4f7ff 0%, #eef3ff 100%);
  box-sizing: border-box;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero,
.card,
.list-card,
.editor-card,
.summary-card,
.topic-card,
.article-card {
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(85, 105, 168, 0.08);
}

.hero,
.card,
.list-card,
.editor-card,
.summary-card,
.topic-card,
.article-card {
  padding: 24rpx;
  box-sizing: border-box;
}

.kicker {
  font-size: 20rpx;
  color: #4f46e5;
  letter-spacing: 1.2rpx;
}

.title {
  font-size: 44rpx;
  line-height: 1.16;
  font-weight: 700;
  color: #101828;
}

.desc {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #667085;
}

.progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.progress-main {
  font-size: 24rpx;
  color: #344054;
  font-weight: 600;
}

.progress-step {
  font-size: 22rpx;
  color: #6366f1;
  font-weight: 700;
}

.label {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #344054;
  font-weight: 600;
}

.textarea,
.input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f8faff;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #101828;
}

.input {
  min-height: 96rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4338ca;
  font-size: 24rpx;
}

.chip-active {
  background: #4338ca;
  color: #ffffff;
}

.footer {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toolbar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn,
.btn-secondary,
.btn-text {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.btn::after,
.btn-secondary::after,
.btn-text::after {
  border: none;
}

.btn {
  flex: 1;
  min-height: 92rpx;
  background: linear-gradient(135deg, #4f46e5 0%, #2563eb 100%);
  color: #ffffff;
  font-weight: 700;
}

.btn-secondary {
  flex: 1;
  min-height: 92rpx;
  background: #ffffff;
  color: #344054;
  border: 2rpx solid #d0d5dd;
}

.btn-small {
  min-height: 76rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.btn-text {
  padding: 0;
  min-height: auto;
  color: #4f46e5;
  background: transparent;
  justify-content: flex-start;
}

.muted {
  font-size: 24rpx;
  color: #667085;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4338ca;
  font-size: 22rpx;
  font-weight: 600;
}

.card-title {
  font-size: 30rpx;
  line-height: 1.35;
  color: #101828;
  font-weight: 700;
}

.card-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #475467;
}

.card-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.card-action {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4338ca;
  font-size: 24rpx;
  font-weight: 600;
}

.notice {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #eef4ff;
  font-size: 24rpx;
  line-height: 1.5;
  color: #344054;
}

.empty {
  padding: 36rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  color: #667085;
}
