.keywords-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f7ff 0%, #eef4ff 100%);
  overflow: hidden;
}

.keywords-orb {
  position: absolute;
  top: 200rpx;
  right: -100rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  filter: blur(22rpx);
}

.keywords-stack {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  gap: 16rpx;
  padding: 16rpx 40rpx calc(142rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.keywords-content {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  overflow: auto;
}

.keywords-hero {
  padding: 24rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
}

.keywords-kicker {
  font-size: 23rpx;
  color: #dce7ff;
  font-weight: 600;
}

.keywords-title {
  margin-top: 8rpx;
  font-size: 54rpx;
  line-height: 1.16;
  color: #ffffff;
  font-weight: 700;
}

.keywords-line {
  width: 100%;
  height: 2rpx;
  margin-top: 12rpx;
  background: rgba(255, 255, 255, 0.22);
}

.keywords-desc {
  margin-top: 12rpx;
  font-size: 29rpx;
  line-height: 1.5;
  color: #e5edff;
}

.keywords-card {
  min-height: 756rpx;
  padding: 20rpx;
  border-radius: 48rpx;
  background: #ffffff;
}

.keywords-input {
  width: 100%;
  min-height: 716rpx;
  font-size: 31rpx;
  line-height: 1.7;
  color: #344054;
}

.keywords-hint {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #d8e5ff;
  color: #2947d3;
  font-size: 23rpx;
  font-weight: 600;
}

.sample-btn,
.btn-secondary,
.btn-primary {
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: block;
  padding: 0;
}

.sample-btn {
  align-self: flex-start;
  padding: 0 28rpx;
  background: #ffffff;
  color: #2947d3;
  border: 1rpx solid #c9d7ff;
}

.footer-row {
  display: flex;
  gap: 16rpx;
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

.btn-secondary,
.btn-primary {
  flex: 1;
}

.btn-secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d0d5dd;
}

.btn-primary {
  background: #2947d3;
  color: #ffffff;
}

.sample-btn::after,
.btn-secondary::after,
.btn-primary::after {
  border: none;
}
