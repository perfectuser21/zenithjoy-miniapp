<view class="keywords-page">
  <view class="keywords-orb"></view>
  <view class="keywords-stack">
    <view class="keywords-content">
      <view class="keywords-hero">
        <view class="keywords-kicker">{{heroCard.kicker}}</view>
        <view class="keywords-title">{{heroCard.title}}</view>
        <view class="keywords-line"></view>
        <view class="keywords-desc">{{heroCard.description}}</view>
      </view>

      <view class="keywords-card">
        <textarea
          class="keywords-input"
          maxlength="-1"
          value="{{keywordsText}}"
          bindinput="handleInput"
          placeholder="例如：\n副业赚钱\n小红书起号\n为什么普通人做内容总是坚持不下去"
        />
      </view>

      <view class="keywords-hint">请至少输入 1 个关键词或热点信息</view>
      <button class="sample-btn" bindtap="useSample">填入示例</button>
    </view>

    <view class="footer-row">
      <button class="btn-secondary" bindtap="skipStep">跳过这步</button>
      <button class="btn-primary" bindtap="saveAndNext">填写灵感</button>
    </view>
  </view>
</view>
