@import "/styles/pencil-theme.wxss";
.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 0rpx);
  background: #FFFFFF;
  border-top: 1rpx solid #E5E7EB;
  pointer-events: auto;
}

.tabbar-pill {
  display: flex;
  align-items: stretch;
  min-height: 104rpx;
  gap: 4rpx;
  padding: 6rpx 20rpx 6rpx;
  box-sizing: border-box;
  border-radius: 0;
  background: #FFFFFF;
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.tab-item-active {
  background: linear-gradient(180deg, #7D78FF 0%, #615AED 55%, #4841C4 100%);
}

.tab-icon {
  width: 28rpx;
  height: 28rpx;
}

.tab-text {
  font-size: 27rpx;
  line-height: 1;
  font-weight: 600;
  color: #8E90A6;
}

.tab-item-active .tab-text {
  color: #FFFFFF;
  font-weight: 700;
}
