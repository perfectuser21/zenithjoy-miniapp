/* Neon Tech Theme utilities (opt-in) */

/* Base backgrounds */
.bg-sky {
  min-height: 100vh;
  background:
    radial-gradient(circle at 14% 18%, rgba(60, 242, 255, 0.16), transparent 32%),
    radial-gradient(circle at 82% 10%, rgba(122, 91, 255, 0.18), transparent 30%),
    linear-gradient(180deg, #050914 0%, #0a1020 36%, #0d1428 100%);
  color: #c6d4f5;
}

/* Surfaces */
.panel {
  background: rgba(16, 26, 46, 0.88);
  border: 1rpx solid rgba(99, 182, 255, 0.24);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 42rpx rgba(5, 12, 36, 0.32);
}

.panel-ghost {
  background: rgba(16, 26, 46, 0.7);
  border: 1rpx solid rgba(99, 182, 255, 0.12);
  border-radius: 24rpx;
}

.glass { backdrop-filter: blur(16rpx); }

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(60, 242, 255, 0), rgba(60, 242, 255, 0.6), rgba(122, 91, 255, 0));
  margin: 16rpx 0;
}

/* Text */
.text-hero { color: #f4f7ff; font-weight: 700; }
.text-sub { color: #c6d4f5; }
.text-dim { color: #93a6cc; }
.text-accent { color: #3cf2ff; }

/* Buttons */
.btn-base {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 28rpx;
  height: 84rpx;
  padding: 0 32rpx;
  border-radius: 999rpx;
  border: 0;
}

.btn-primary {
  composes: btn-base;
  background: linear-gradient(135deg, #3cf2ff 0%, #7a5bff 52%, #ff6fd8 100%);
  color: #0b0f1d;
  box-shadow: 0 16rpx 36rpx rgba(60, 242, 255, 0.3);
}

.btn-ghost {
  composes: btn-base;
  background: rgba(16, 26, 46, 0.82);
  color: #c6d4f5;
  border: 1rpx solid rgba(99, 182, 255, 0.28);
}

.pill { border-radius: 999rpx; }

/* Chips & badges */
.chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(21, 32, 52, 0.9);
  color: #9fd7ff;
  border: 1rpx solid rgba(99, 182, 255, 0.2);
  font-size: 22rpx;
}

.chip-accent { background: rgba(60, 242, 255, 0.18); color: #3cf2ff; border-color: rgba(60, 242, 255, 0.32); }
.chip-soft { background: rgba(122, 91, 255, 0.16); color: #dcd4ff; border-color: rgba(122, 91, 255, 0.26); }

/* Message bubbles */
.bubble-user {
  background: linear-gradient(180deg, #3cf2ff 0%, #7a5bff 100%);
  color: #0b0f1d;
  border-radius: 22rpx 8rpx 22rpx 22rpx;
  padding: 24rpx 26rpx;
  box-shadow: 0 12rpx 28rpx rgba(60, 242, 255, 0.2);
}

.bubble-ai {
  background: rgba(16, 26, 46, 0.9);
  color: #e8f1ff;
  border-radius: 8rpx 22rpx 22rpx 22rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid rgba(99, 182, 255, 0.22);
  box-shadow: 0 12rpx 28rpx rgba(5, 12, 36, 0.24);
}

/* Grids */
.grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; }
.grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14rpx; }

/* Cards */
.card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(16, 26, 46, 0.9);
  border: 1rpx solid rgba(99, 182, 255, 0.18);
  box-shadow: 0 16rpx 36rpx rgba(5, 12, 36, 0.28);
}

.card-gradient {
  padding: 26rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, rgba(60, 242, 255, 0.18) 0%, rgba(122, 91, 255, 0.18) 100%);
  border: 1rpx solid rgba(99, 182, 255, 0.18);
  box-shadow: 0 18rpx 42rpx rgba(5, 12, 36, 0.26);
}

/* Status */
.success { color: #3fd4a9; }
.warning { color: #ffc75c; }
.danger { color: #ff6f6f; }

/* Icons & dots */
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
  background: #3cf2ff;
}

.dot-warning { background: #ffc75c; }
.dot-success { background: #3fd4a9; }
.dot-danger { background: #ff6f6f; }

/* Input bar */
.input-bar {
  background: rgba(10, 14, 26, 0.94);
  border-top: 1rpx solid rgba(99, 182, 255, 0.18);
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.18);
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
}

.input-field {
  flex: 1;
  height: 84rpx;
  background: rgba(16, 26, 46, 0.9);
  color: #e8f1ff;
  border-radius: 28rpx;
  padding: 0 30rpx;
  border: 1rpx solid rgba(99, 182, 255, 0.2);
}

.input-send {
  width: 132rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #3cf2ff 0%, #7a5bff 100%);
  color: #0b0f1d;
  font-weight: 700;
  font-size: 28rpx;
}

/* Hero chips and labels */
.kicker { letter-spacing: 6rpx; color: #3cf2ff; font-size: 18rpx; }
.label-ghost { color: #93a6cc; font-size: 22rpx; }

